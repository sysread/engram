#!/usr/bin/env elixir

#-------------------------------------------------------------------------------
# Initialize logger
#-------------------------------------------------------------------------------
{:ok, cfg} = :logger.get_handler_config(:default)
cfg = Map.update!(cfg, :config, &Map.put(&1, :type, :standard_error))
:ok = :logger.remove_handler(:default)
:ok = :logger.add_handler(:default, :logger_std_h, cfg)
:ok = :logger.set_primary_config(:level, :info)

#-------------------------------------------------------------------------------
# Install dependencies
#-------------------------------------------------------------------------------
Mix.install([
  {:bumblebee, "~> 0.6"},
  {:exla, "~> 0.9"},
  {:exqlite, "~> 0.27"},
  {:jason, "~> 1.4"},
])

#-------------------------------------------------------------------------------
# Tool behaviour
#-------------------------------------------------------------------------------
defmodule McpTool do
  @type tool_spec :: %{
    name: binary,
    description: binary,
    inputSchema: map
  }

  @callback spec() :: tool_spec
  @callback call(map) :: {:ok, binary} | {:error, binary}
end

#-------------------------------------------------------------------------------
# MCP Server implementation (stdio)
#-------------------------------------------------------------------------------
defmodule McpServer do
  @jsonrpc_invalid_params -32602

  @service %{
    protocolVersion: "2024-11-05",
    serverInfo: %{name: "engram", version: "0.1.0"},
    capabilities: %{tools: %{}}
  }

  #-----------------------------------------------------------------------------
  # Main loop
  #-----------------------------------------------------------------------------
  def run do
    App.log(:info, "Tools: #{inspect(tools_map(), pretty: true, limit: :infinity)}")
    App.log(:info, "Engram ready")
    loop()
  end

  defp loop do
    case IO.read(:stdio, :line) do
      :eof -> :ok
      "\n" -> loop()
      {:error, reason} -> App.log(:error, "error reading from stdin", reason)

      line ->
        line
        |> String.trim()
        |> Jason.decode()
        |> case do
          {:ok, nil} -> :ok
          {:ok, msg} -> handle_request(msg)
          {:error, reason} -> App.log(:error, "error parsing request", %{input: line, message: reason})
        end

        loop()
    end
  end

  #-----------------------------------------------------------------------------
  # Message handling
  #-----------------------------------------------------------------------------
  # Notifications have no id and receive no response
  defp handle_request(%{"method" => "notifications/" <> _}), do: :ok

  # Requests have an id and always receive a response
  defp handle_request(%{"id" => id, "method" => method} = msg) do
    method
    |> handle_method(msg)
    |> case do
      {:ok, result} -> reply(id, result)
      {:error, code, reason} -> fail(id, code, reason)
      {:tool_error, reason} -> reply(id, %{content: [%{type: "text", text: reason}], isError: true})
    end
  end

  defp handle_method("initialize", _), do: {:ok, @service}

  defp handle_method("tools/list", _) do
    tools()
    |> Enum.map(& &1.spec())
    |> then(&{:ok, %{tools: &1}})
  end

  defp handle_method("tools/call", %{"params" => %{"name" => name} = params}) do
    tools_map()
    |> Map.get(name)
    |> case do
      nil ->
        {:error, @jsonrpc_invalid_params, "Unknown tool: #{name}"}

      tool ->
        args = Map.get(params, "arguments", %{})

        case tool.call(args) do
          {:ok, text} -> {:ok, %{content: [%{type: "text", text: text}]}}
          {:error, reason} -> {:tool_error, reason}
        end
    end
  end

  #-----------------------------------------------------------------------------
  # Communication helpers
  #-----------------------------------------------------------------------------
  defp reply(id, result), do: %{id: id, result: result} |> write()
  defp fail(id, code, message), do: %{id: id, error: %{code: code, message: message}} |> write()

  defp write(%{} = msg) do
    msg
    |> Map.put(:jsonrpc, "2.0")
    |> Jason.encode!()
    |> then(&(&1 <> "\n"))
    |> IO.write()
  end

  #-----------------------------------------------------------------------------
  # Tool discovery
  #-----------------------------------------------------------------------------
  defp tools do
    :code.all_loaded()
    |> Enum.map(&elem(&1, 0))
    |> Enum.filter(&function_exported?(&1, :spec, 0))
    |> Enum.filter(&function_exported?(&1, :call, 1))
  end

  defp tools_map do
    tools()
    |> Enum.map(fn tool -> {tool.spec().name, tool} end)
    |> Map.new()
  end
end

#-------------------------------------------------------------------------------
# Tools
#-------------------------------------------------------------------------------
defmodule StoreMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "remember",
      description: "Persists a piece of information in the current store",
      inputSchema: %{
        type: "object",
        required: ["label", "data"],
        properties: %{
          label: %{
            type: "string",
            description: "A label for the information to remember"
          },
          data: %{
            type: "string",
            description: "The information to remember"
          },
          overwrite: %{
            type: "boolean",
            description: "Set to true to overwrite an existing memory with the same label"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"label" => label, "data" => data} = args) do
    overwrite = Map.get(args, "overwrite", false)

    case Store.write(label, data, overwrite: overwrite) do
      :ok -> {:ok, "'#{label}' has been remembered"}
      {:error, reason} -> {:error, reason}
    end
  end
end

defmodule ListMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "list",
      description: "Lists all entries in the current store",
      inputSchema: %{
        type: "object",
        properties: %{}
      }
    }
  end

  @impl true
  def call(_) do
    Store.list_entries()
    |> Enum.join("\n")
    |> then(&{:ok, &1})
  end
end

defmodule RecallMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "recall",
      description: "Recalls information from the current store relevant to a query",
      inputSchema: %{
        type: "object",
        required: ["query"],
        properties: %{
          query: %{
            type: "string",
            description: "A query to recall relevant information for"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"query" => query}) do
    Store.search(query)
    |> Enum.map(fn {_score, entry} -> entry end)
    |> Enum.join("\n\n-----\n\n")
    |> then(&{:ok, &1})
  end
end

#-------------------------------------------------------------------------------
# Common app bits
#-------------------------------------------------------------------------------
defmodule App do
  def help(exit_code \\ 0) do
    IO.puts("""
    Usage: engram [options]

    Options:
      --help    | -h  Show this help message
      --verbose | -v  Enable verbose output
      --store <name>  Use the named store

    Operations:
      --create <name>         Create a new store
      --list                  List existing stores
      --remove <name>          Remove a store
      --store <name> --reindex  Regenerate all embeddings

    If no operation is specified, starts the MCP server using the stdio transport
    with the specified store.
    """)

    System.halt(exit_code)
  end

  #-----------------------------------------------------------------------------
  # Logging helpers
  #-----------------------------------------------------------------------------
  require Logger

  def log(level, msg), do: Logger.log(level, msg)

  def log(level, msg, extra) do
    log(level, msg <> "\n\n" <> inspect(extra, pretty: true, limit: :infinity))
  end

  def debug(msg), do: log(:debug, msg)
  def debug(msg, extra), do: log(:debug, msg, extra)
  def info(msg), do: log(:info, msg)
  def info(msg, extra), do: log(:info, msg, extra)
  def error(msg), do: log(:error, msg)
  def error(msg, extra), do: log(:error, msg, extra)
  def warn(msg), do: log(:warn, msg)
  def warn(msg, extra), do: log(:warn, msg, extra)
end

#-------------------------------------------------------------------------------
# Contexts
#-------------------------------------------------------------------------------
defmodule Embeddings do
  @model "sentence-transformers/all-MiniLM-L12-v2"
  @serving_name __MODULE__

  def model(), do: @model

  # Loads the embedding model and tokenizer from HuggingFace, then starts an
  # Nx.Serving process for batched inference. Must be called before embed/1.
  def start do
    App.log(:info, "Loading embedding model #{@model}...")

    {:ok, model} = Bumblebee.load_model({:hf, @model})
    {:ok, tokenizer} = Bumblebee.load_tokenizer({:hf, @model})

    serving =
      Bumblebee.Text.TextEmbedding.text_embedding(
        model,
        tokenizer,
        compile: [batch_size: 2, sequence_length: 128],
        defn_options: [compiler: EXLA],
        output_pool: :mean_pooling,
        output_attribute: :hidden_state
      )

    Nx.Serving.start_link(
      serving: serving,
      name: @serving_name,
      batch_size: 2,
      batch_timeout: 100
    )
  end

  # Embeds a single string, returns {:ok, tensor}.
  def embed(text) do
    case Nx.Serving.batched_run(@serving_name, text) do
      %{embedding: embedding} -> {:ok, embedding}
      error -> {:error, error}
    end
  end

  # Cosine similarity between two pre-computed embedding tensors.
  def tensor_similarity(e1, e2), do: cosine_similarity(e1, e2)

  defp cosine_similarity(e1, e2) do
    e1 = Nx.flatten(e1)
    e2 = Nx.flatten(e2)

    Nx.divide(Nx.dot(e1, e2), Nx.multiply(Nx.LinAlg.norm(e1), Nx.LinAlg.norm(e2)))
    |> Nx.to_number()
  end
end

defmodule State do
  use Agent

  def start_link(), do: Agent.start_link(fn -> %{} end, name: __MODULE__)

  def db(ref), do: Agent.update(__MODULE__, &Map.put(&1, :db, ref))
  def db(), do: Agent.get(__MODULE__, &Map.get(&1, :db))
end

defmodule Store do
  @max_results 10

  #-----------------------------------------------------------------------------
  # Store management -- each store is a SQLite database file under
  # ~/.config/engram/<name>.db. The schema is created on first open.
  #-----------------------------------------------------------------------------
  def base_path(), do: [System.user_home!(), ".config", "engram"] |> Path.join()
  defp db_path(name), do: Path.join(base_path(), name <> ".db")

  def init() do
    File.mkdir_p!(base_path())
  end

  def open(name) do
    path = db_path(name)

    unless File.exists?(path) do
      {:error, "Store '#{name}' does not exist. Use --create to create it."}
    else
      {:ok, db} = Exqlite.Sqlite3.open(path)
      State.db(db)
      :ok
    end
  end

  def create(name) do
    init()
    path = db_path(name)

    if File.exists?(path) do
      {:error, "Store '#{name}' already exists."}
    else
      {:ok, db} = Exqlite.Sqlite3.open(path)
      migrate(db)
      Exqlite.Sqlite3.close(db)
      {:ok, name}
    end
  end

  def list_stores() do
    init()

    base_path()
    |> File.ls!()
    |> Enum.filter(&String.ends_with?(&1, ".db"))
    |> Enum.map(&String.replace_suffix(&1, ".db", ""))
    |> then(&{:ok, &1})
  end

  def remove_store(name) do
    path = db_path(name)

    if File.exists?(path) do
      File.rm!(path)
      :ok
    else
      {:error, "Store '#{name}' does not exist."}
    end
  end

  #-----------------------------------------------------------------------------
  # Schema -- single table for entries with content and cached embeddings.
  # The model column tracks which embedding model generated the vector, so
  # we can detect when a reindex is needed after a model change.
  #-----------------------------------------------------------------------------
  defp migrate(db) do
    :ok = Exqlite.Sqlite3.execute(db, """
      CREATE TABLE IF NOT EXISTS entries (
        slug TEXT PRIMARY KEY,
        label TEXT NOT NULL,
        content TEXT NOT NULL,
        embedding BLOB,
        model TEXT
      )
    """)
  end

  #-----------------------------------------------------------------------------
  # Entry operations
  #-----------------------------------------------------------------------------
  def list_entries() do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT label FROM entries ORDER BY label")
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)

    rows |> Enum.map(fn [label] -> label end)
  end

  def write(label, data, opts \\ []) do
    db = State.db()
    overwrite = Keyword.get(opts, :overwrite, false)
    slug = slugify(label)
    content = "# #{label}\n\n#{data}"

    # Check for existing entry
    case entry_exists?(slug) do
      true when not overwrite ->
        {:error, "A memory with label '#{label}' already exists. " <>
          "Read it first, then decide whether to overwrite, merge, or create a separate memory. " <>
          "Pass overwrite: true to replace it."}

      _ ->
        {:ok, embedding} = Embeddings.embed(content)
        blob = {:blob, :erlang.term_to_binary(embedding)}

        {:ok, stmt} = Exqlite.Sqlite3.prepare(db, """
          INSERT INTO entries (slug, label, content, embedding, model)
          VALUES (?1, ?2, ?3, ?4, ?5)
          ON CONFLICT(slug) DO UPDATE SET
            label = excluded.label,
            content = excluded.content,
            embedding = excluded.embedding,
            model = excluded.model
        """)

        :ok = Exqlite.Sqlite3.bind(stmt, [slug, label, content, blob, Embeddings.model()])
        :done = Exqlite.Sqlite3.step(db, stmt)
        :ok = Exqlite.Sqlite3.release(db, stmt)
        :ok
    end
  end

  def read(slug) do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT content FROM entries WHERE slug = ?1")
    :ok = Exqlite.Sqlite3.bind(stmt, [slug])

    result =
      case Exqlite.Sqlite3.step(db, stmt) do
        {:row, [content]} -> {:ok, content}
        :done -> {:error, "Entry '#{slug}' not found."}
      end

    :ok = Exqlite.Sqlite3.release(db, stmt)
    result
  end

  def search(query, max_results \\ @max_results) do
    db = State.db()
    {:ok, query_embedding} = Embeddings.embed(query)

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
      "SELECT content, embedding FROM entries WHERE embedding IS NOT NULL"
    )

    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)

    rows
    |> Enum.map(fn [content, embedding_blob] ->
      embedding = :erlang.binary_to_term(embedding_blob)
      score = Embeddings.tensor_similarity(query_embedding, embedding)
      {score, content}
    end)
    |> Enum.sort_by(&elem(&1, 0), :desc)
    |> Enum.take(max_results)
  end

  #-----------------------------------------------------------------------------
  # Helpers
  #-----------------------------------------------------------------------------
  defp entry_exists?(slug) do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT 1 FROM entries WHERE slug = ?1")
    :ok = Exqlite.Sqlite3.bind(stmt, [slug])
    result = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)

    match?({:row, _}, result)
  end

  def reindex() do
    db = State.db()
    model = Embeddings.model()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT slug, content FROM entries")
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)

    {:ok, update_stmt} = Exqlite.Sqlite3.prepare(db,
      "UPDATE entries SET embedding = ?1, model = ?2 WHERE slug = ?3"
    )

    Enum.each(rows, fn [slug, content] ->
      App.info("Reindexing '#{slug}'...")
      {:ok, embedding} = Embeddings.embed(content)
      blob = {:blob, :erlang.term_to_binary(embedding)}
      :ok = Exqlite.Sqlite3.bind(update_stmt, [blob, model, slug])
      :done = Exqlite.Sqlite3.step(db, update_stmt)
    end)

    :ok = Exqlite.Sqlite3.release(db, update_stmt)
    App.info("Reindex complete. #{length(rows)} entries updated.")
  end

  defp slugify(label) do
    label
    |> String.trim()
    |> String.downcase()
    |> String.replace(~r/[^a-z0-9\s_-]/, "")
    |> String.replace(~r/[\s_]+/, "-")
  end
end

#-------------------------------------------------------------------------------
# Process ARGV
#-------------------------------------------------------------------------------
args =
  System.argv()
  |> OptionParser.parse(
    switches: [
      help: :boolean,
      verbose: :boolean,
      create: :string,
      list: :boolean,
      remove: :string,
      reindex: :boolean,
      store: :string,
    ],
    aliases: [
      h: :help,
      v: :verbose,
    ]
  )
  |> then(fn {args, _, _} -> args end)
  |> Map.new()

# Override logger level if --verbose is set
if args[:verbose] do
  :logger.set_primary_config(:level, :debug)
end

State.start_link()

#-------------------------------------------------------------------------------
# Dispatch
#-------------------------------------------------------------------------------
case args do
  %{help: true} ->
    App.help(0)

  %{create: name} ->
    case Store.create(name) do
      {:ok, name} -> App.info("Created store '#{name}'")
      {:error, reason} -> App.error(reason)
    end

  %{list: true} ->
    case Store.list_stores() do
      {:ok, []} ->
        IO.puts("No stores found. Use --create <name> to create one.")

      {:ok, stores} ->
        IO.puts("Existing stores:")
        stores |> Enum.each(&IO.puts("  - #{&1}"))
    end

  %{remove: name} ->
    case Store.remove_store(name) do
      :ok -> App.info("Removed store '#{name}'")
      {:error, reason} -> App.error(reason)
    end

  %{store: name, reindex: true} ->
    case Store.open(name) do
      :ok ->
        Nx.global_default_backend(EXLA.Backend)
        Embeddings.start()
        Store.reindex()

      {:error, reason} ->
        App.error(reason)
        System.halt(1)
    end

  %{store: name} ->
    case Store.open(name) do
      :ok ->
        App.info("Using store '#{name}'")
        Nx.global_default_backend(EXLA.Backend)
        Embeddings.start()
        McpServer.run()

      {:error, reason} ->
        App.error(reason)
        System.halt(1)
    end

  _ ->
    App.help(1)
end
