        :ok -> {:ok, "[forgotten] #{store} :: #{label}"}
        {:error, reason} -> {:error, reason}
      end
    end
  end
end

defmodule ShowMemory do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "show",
      description: "Returns the full content of a single memory looked up by exact label. " <>
        "Use this to read a memory in full when `list` or `recall` has surfaced it by label.",
      inputSchema: %{
        type: "object",
        required: ["label"],
        properties: %{
          label: %{
            type: "string",
            description: "The exact label of the memory to read"
          },
          store: %{
            type: "string",
            description: "Which store to read from (defaults to the primary project store)"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"label" => label} = args) do
    slug = Store.slugify(label)

    with {:ok, store} <- State.require_store(args) do
      case Store.read(store, slug) do
        {:ok, entry} ->
          scope = Store.format_scope(store, entry.branch)

          meta =
            Store.format_meta([
              {entry.confidence, &"confidence:#{&1}"},
              {entry.created_at, &"created:#{&1}"},
              {entry.updated_at, &"updated:#{&1}"}
            ])

          header =
            if meta == "" do
              "#{scope} #{entry.label}"
            else
              "#{scope} #{entry.label} (#{meta})"
            end

          {:ok, "#{header}\n\n#{Store.strip_content_heading(entry.content)}"}

        {:error, reason} ->
          {:error, reason}
      end
    end
  end
end

defmodule MoveMemory do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "move",
      description: "Moves a memory from one store to another. The move preserves the memory's " <>
        "embedding (it keeps matching in recall, no reindex needed) and its timestamps. " <>
        "Use this to refile a memory that was saved to the wrong store. " <>
        "Refuses to overwrite a memory that already exists in the destination.",
      inputSchema: %{
        type: "object",
        required: ["label", "to"],
        properties: %{
          label: %{
            type: "string",
            description: "The exact label of the memory to move"
          },
          to: %{
            type: "string",
            description: "Destination store to move the memory into"
          },
          from: %{
            type: "string",
            description: "Source store to move the memory out of (defaults to the primary project store)"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"label" => label, "to" => dest} = args) do
    with {:ok, src} <- State.require_store(args, "from"),
         :ok <- State.authorize_store(dest) do
      case Store.move(src, dest, [label]) do
        {:ok, _} -> {:ok, "[moved] #{src} -> #{dest} :: #{label}"}
        {:error, reason} -> {:error, reason}
      end
    end
  end

  def call(_) do
    {:error, "Missing or invalid arguments. Required: label (string), to (string, destination store). " <>
      "Optional: from (source store, defaults to the primary store)."}
  end
end

#-------------------------------------------------------------------------------
# Common app bits
#-------------------------------------------------------------------------------
defmodule App do
  def help(exit_code \\ 0) do
    IO.puts(:standard_error, """
    SYNOPSIS
      engram <command> [options]

    DESCRIPTION
      engram is a local storage system for LLMs to persist information across interactions.

    OPTIONS
      --help    | -h      Show this help message
      --verbose | -v      Enable verbose output

    COMMANDS
      list-stores                          List existing stores
      list             <name>              List memory labels in a store
      create           <name>              Create a new store
      remove           <name>              Remove a store
      reindex          <name>              Regenerate all embeddings
      find-duplicates  [-H] <name>         Find memories with similar content (TSV: score\ta\tb; -H adds header)
      remember         <name> --label...   Save a memory (--label, --content, --overwrite, --branch, --confidence)
      forget           <name> <label>      Remove a memory by label
      move             <src> <dst> <slug>...  Move memories to another store (keeps embedding)
      show             <name> <slug>       Display a single memory by slug
      dump             <name> ...          Output all memories for one or more stores
      recall           <name> ... -- <q>   Semantic search across one or more stores
      mcp              <name> ... | --all  Start the MCP server (stdio transport)
      setup                                Configure engram for the current directory

    SETUP
      cd /path/to/myproject
      engram setup
    """)

    System.halt(exit_code)
  end

  # Resolves the absolute path to this script, following symlinks recursively.
  def script_path do
    resolve_symlinks(__ENV__.file |> Path.expand())
  end

  defp resolve_symlinks(path) do
    case File.read_link(path) do
      {:ok, target} ->
        resolved =
          if Path.type(target) == :relative do
            path |> Path.dirname() |> Path.join(target) |> Path.expand()
          else
            Path.expand(target)
          end

        resolve_symlinks(resolved)

      {:error, _} ->
        path
    end
  end

  #-----------------------------------------------------------------------------
  # Logging helpers
  #-----------------------------------------------------------------------------
  require Logger

  def log(level, msg), do: Logger.log(level, msg)

  def log(level, msg, extra) do
    log(level, msg <> "\n\n" <> inspect(extra, pretty: true, limit: :infinity))
  end

  def debug(msg), do: log(:debug, msg)
  def debug(msg, extra), do: log(:debug, msg, extra)
  def info(msg), do: log(:info, msg)
  def info(msg, extra), do: log(:info, msg, extra)
  def error(msg), do: log(:error, msg)
  def error(msg, extra), do: log(:error, msg, extra)
  def warn(msg), do: log(:warn, msg)
  def warn(msg, extra), do: log(:warn, msg, extra)

  # Writes directly to stderr and halts. Logger.log is async and
  # System.halt kills the VM before the handler flushes its buffer.
  def fatal(msg) do
    IO.puts(:standard_error, "error: #{msg}")
    System.halt(1)
  end
end

#-------------------------------------------------------------------------------
# Contexts
#-------------------------------------------------------------------------------
defmodule Embeddings do
  @default_model "sentence-transformers/all-MiniLM-L12-v2"
  @serving_name __MODULE__

  def model(), do: System.get_env("ENGRAM_MODEL") || @default_model

  # Ensures the embedding model is loaded and the Nx.Serving is running.
  # Safe to call multiple times -- subsequent calls are no-ops.
  def ensure_started do
    unless Process.whereis(@serving_name) do
      Nx.global_default_backend(EXLA.Backend)
      start()
    end

    :ok
  end

  # Loads the embedding model and tokenizer from HuggingFace, then starts an
  # Nx.Serving process for batched inference. Must be called before embed/1.
  def start do
    model_name = model()
    App.log(:info, "Loading embedding model #{model_name}...")

    {:ok, model} = Bumblebee.load_model({:hf, model_name})
    {:ok, tokenizer} = Bumblebee.load_tokenizer({:hf, model_name})

    serving =
      Bumblebee.Text.TextEmbedding.text_embedding(
        model,
        tokenizer,
        compile: [batch_size: 2, sequence_length: 128],
        defn_options: [compiler: EXLA],
        output_pool: :mean_pooling,
        output_attribute: :hidden_state
      )

    Nx.Serving.start_link(
      serving: serving,
      name: @serving_name,
      batch_size: 2,
      batch_timeout: 100
    )
  end

  # Embeds a single string, returns {:ok, tensor}.
  def embed(text) do
    case Nx.Serving.batched_run(@serving_name, text) do
      %{embedding: embedding} -> {:ok, embedding}
      error -> {:error, error}
    end
  end

  # Cosine similarity between two pre-computed embedding tensors.
  def tensor_similarity(e1, e2), do: cosine_similarity(e1, e2)

  defp cosine_similarity(e1, e2) do
    e1 = Nx.flatten(e1)
    e2 = Nx.flatten(e2)

    Nx.divide(Nx.dot(e1, e2), Nx.multiply(Nx.LinAlg.norm(e1), Nx.LinAlg.norm(e2)))
    |> Nx.to_number()
  end
end

defmodule State do
  use Agent

  def start_link(), do: Agent.start_link(fn -> %{db: nil, stores: []} end, name: __MODULE__)

  def db(ref), do: Agent.update(__MODULE__, &Map.put(&1, :db, ref))
  def db(), do: Agent.get(__MODULE__, &Map.get(&1, :db))

  # The list of store names this instance is serving (set at startup)
  def stores(names), do: Agent.update(__MODULE__, &Map.put(&1, :stores, names))
  def stores(), do: Agent.get(__MODULE__, &Map.get(&1, :stores))

  # The default store is the first one listed (the "primary" project store)
  def default_store(), do: stores() |> List.first()

  # Guards MCP tool calls against the configured store list. Returns :ok if the
  # store is in the active set, or {:error, reason} if not.
  def authorize_store(store) do
    if store in stores() do
      :ok
    else
      {:error, "Store '#{store}' is not available in this session. Active stores: #{Enum.join(stores(), ", ")}"}
    end
  end

  # Extracts a store name from tool arguments, defaulting to the primary project
  # store, then authorizes it. Returns {:ok, store} or {:error, reason}.
  def require_store(args, key \\ "store") do
    store = Map.get(args, key, default_store())

    case authorize_store(store) do
      :ok -> {:ok, store}
      error -> error
    end
  end
end

defmodule Store do
  @max_results 10
  @global_store "global"

  defmodule Entry do
    defstruct [:slug, :store, :label, :content, :branch, :confidence, :created_at, :updated_at]
  end

  #-----------------------------------------------------------------------------
  # Database management -- all stores live in a single SQLite database at
  # ~/.config/engram/engram.db. Each store is a named partition; entries are
  # scoped by a (slug, store) composite key. WAL mode enables concurrent
  # readers across multiple engram processes sharing the same db file.
  #-----------------------------------------------------------------------------
  def base_path() do
    System.get_env("ENGRAM_DATA_DIR") || Path.join(System.user_home!(), ".config/engram")
  end
  defp db_path(), do: Path.join(base_path(), "engram.db")

  def init() do
    File.mkdir_p!(base_path())
  end

  # Opens the shared database, sets WAL mode for safe multi-process access,
  # and runs migrations. Called once at startup.
  def open_db() do
    init()

    with {:ok, db} <- Exqlite.Sqlite3.open(db_path()),
         :ok <- Exqlite.Sqlite3.execute(db, "PRAGMA journal_mode=WAL"),
         :ok <- Exqlite.Sqlite3.execute(db, "PRAGMA busy_timeout=5000"),
         :ok <- migrate(db) do
      State.db(db)
      :ok
    else
      {:error, reason} -> {:error, "Failed to open database: #{inspect(reason)}"}
    end
  end

  # Validates that all requested stores exist in the database. Returns :ok
  # if all exist, or an error naming the missing ones.
  def validate_stores(names) do
    missing = Enum.reject(names, &store_exists?/1)

    if missing == [] do
      :ok
    else
      {:error, "Store(s) not found: #{Enum.join(missing, ", ")}. Use 'create' to create them."}
    end
  end

  def validate_name(name) do
    cond do
      name == "" ->
        {:error, "Store name cannot be empty."}

      String.contains?(name, " ") ->
        {:error, "Store name cannot contain spaces: '#{name}'"}

      not Regex.match?(~r/^[a-zA-Z0-9_-]+$/, name) ->
        {:error, "Store name may only contain letters, numbers, hyphens, and underscores: '#{name}'"}

      true ->
        :ok
    end
  end

  def create(name) do
    with :ok <- validate_name(name),
         :ok <- open_db() do
      if store_exists?(name) do
        {:error, "Store '#{name}' already exists."}
      else
        exec("INSERT INTO stores (name) VALUES (?1)", [name])
        {:ok, name}
      end
    end
  end

  def list_stores() do
    with :ok <- open_db() do
      {:ok, query("SELECT name FROM stores ORDER BY name") |> Enum.map(fn [n] -> n end)}
    end
  end

  def remove_store(name) do
    if store_exists?(name) do
      exec("DELETE FROM entries WHERE store = ?1", [name])
      exec("DELETE FROM stores WHERE name = ?1", [name])
      :ok
    else
      {:error, "Store '#{name}' does not exist."}
    end
  end

  #-----------------------------------------------------------------------------
  # Schema -- stores table tracks named partitions. Entries table holds content
  # and cached embeddings, scoped by store via composite primary key. The model
  # column tracks which embedding model generated the vector so we can detect
  # when a reindex is needed after a model change.
  #
  # branch: nullable TEXT, scopes a memory to a specific git branch. NULL means
  # the memory applies project-wide (all branches). A specific value means the
  # memory is only relevant when working on that branch.
  #
  # confidence: nullable INTEGER 1-10, tracks how well-established an
  # observation is. NULL means unrated. See example-claude.md for the scale.
  #
  # created_at/updated_at: ISO 8601 timestamps for staleness detection.
  #-----------------------------------------------------------------------------
  defp migrate(db) do
    :ok = Exqlite.Sqlite3.execute(db, """
      CREATE TABLE IF NOT EXISTS stores (
        name TEXT PRIMARY KEY
      )
    """)

    :ok = Exqlite.Sqlite3.execute(db, """
      CREATE TABLE IF NOT EXISTS entries (
          slug      TEXT NOT NULL
        , store     TEXT NOT NULL REFERENCES stores(name)
        , label     TEXT NOT NULL
        , content   TEXT NOT NULL
        , embedding BLOB
        , model     TEXT
        , PRIMARY KEY (slug, store)
      )
    """)

    # Additive migrations - each column is added if not already present.
    # SQLite raises an error if the column exists, so we check first.
    columns = table_columns(db, "entries")

    unless "branch" in columns do
      :ok = Exqlite.Sqlite3.execute(db, "ALTER TABLE entries ADD COLUMN branch TEXT")
    end

    unless "confidence" in columns do
      :ok = Exqlite.Sqlite3.execute(db, "ALTER TABLE entries ADD COLUMN confidence INTEGER")
    end

    unless "created_at" in columns do
      :ok = Exqlite.Sqlite3.execute(db, """
        ALTER TABLE entries ADD COLUMN created_at TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
      """)
    end

    unless "updated_at" in columns do
      :ok = Exqlite.Sqlite3.execute(db, """
        ALTER TABLE entries ADD COLUMN updated_at TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
      """)
    end

    # The global store is always available - it holds user preferences and
    # system knowledge shared across all projects.
    :ok = Exqlite.Sqlite3.execute(db,
      "INSERT OR IGNORE INTO stores (name) VALUES ('#{@global_store}')"
    )

    :ok
  end

  defp table_columns(db, table) do
    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "PRAGMA table_info(#{table})")
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    Enum.map(rows, fn [_cid, name | _rest] -> name end)
  end

  #-----------------------------------------------------------------------------
  # Entry operations -- all scoped by store name. When called from MCP tools,
  # the store defaults to State.default_store() if not specified.
  #-----------------------------------------------------------------------------
  # Returns a list of Entry structs with label, branch, confidence, and timestamps.
  def list_entries(store) do
    query("SELECT slug, label, branch, confidence, updated_at FROM entries WHERE store = ?1 ORDER BY label", [store])
    |> Enum.map(fn [slug, label, branch, confidence, updated_at] ->
      %Entry{slug: slug, store: store, label: label, branch: branch, confidence: confidence, updated_at: updated_at}
    end)
  end

  def write(store, label, data, opts \\ []) do
    slug = slugify(label)
    content = "# #{label}\n\n#{data}"
    overwrite = Keyword.get(opts, :overwrite, false)
    branch = Keyword.get(opts, :branch)
    confidence = Keyword.get(opts, :confidence)

    with :ok <- check_overwrite(store, slug, label, overwrite),
         {:ok, embedding} <- maybe_embed(store, slug, content),
         :ok <- upsert_entry(store, slug, label, content, embedding, branch, confidence) do
      :ok
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Failed to write '#{label}': #{inspect(reason)}"}
    end
  end

  def read(store, slug) do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, """
      SELECT slug, label, content, branch, confidence, created_at, updated_at
      FROM entries WHERE slug = ?1 AND store = ?2
    """)

    :ok = Exqlite.Sqlite3.bind(stmt, [slug, store])

    result =
      case Exqlite.Sqlite3.step(db, stmt) do
        {:row, [slug, label, content, branch, confidence, created_at, updated_at]} ->
          {:ok, %Entry{
            slug: slug, store: store, label: label, content: content, branch: branch,
            confidence: confidence, created_at: created_at, updated_at: updated_at
          }}

        :done ->
          {:error, "Entry '#{slug}' not found."}
      end

    :ok = Exqlite.Sqlite3.release(db, stmt)
    result
  end

  # Searches across all active stores (as listed in State.stores()). Results
  # from all stores are merged and ranked by similarity score. When a branch
  # is specified, results include both branch-specific and project-wide
  # (branch IS NULL) entries.
  def search(query, opts \\ []) do
    stores = State.stores()
    max_results = Keyword.get(opts, :max_results, @max_results)
    branch = Keyword.get(opts, :branch)

    with {:ok, query_embedding} <- Embeddings.embed(query),
         {:ok, rows} <- fetch_all_embeddings(stores, branch) do
      rows
      |> Enum.map(fn [slug, content, embedding_blob, store, entry_branch, confidence] ->
        embedding = :erlang.binary_to_term(embedding_blob)
        score = Embeddings.tensor_similarity(query_embedding, embedding)
        {score, %Entry{slug: slug, content: content, store: store, branch: entry_branch, confidence: confidence}}
      end)
      |> Enum.sort_by(&elem(&1, 0), :desc)
      |> Enum.take(max_results)
      |> then(&{:ok, &1})
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Search failed: #{inspect(reason)}"}
    end
  end

  #-----------------------------------------------------------------------------
  # Helpers -- private functions that encapsulate SQLite operations. Public
  # functions use `with` to compose these, reshaping errors into caller-
  # friendly messages at the boundary.
  #-----------------------------------------------------------------------------
  defp store_exists?(name) do
    exists?("SELECT 1 FROM stores WHERE name = ?1", [name])
  end

  defp check_overwrite(store, slug, label, overwrite) do
    case {entry_exists?(store, slug), overwrite} do
      {true, false} ->
        {:error, "A memory with label '#{label}' already exists. " <>
          "Read it first, then decide whether to overwrite, merge, or create a separate memory. " <>
          "Pass overwrite: true to replace it."}
      _ ->
        :ok
    end
  end

  defp entry_exists?(store, slug) do
    exists?("SELECT 1 FROM entries WHERE slug = ?1 AND store = ?2", [slug, store])
  end

  # Skips embedding when the content hasn't changed - avoids expensive model
  # inference for metadata-only updates (e.g. confidence bump). Returns the
  # existing embedding if content matches, or computes a new one.
  defp maybe_embed(store, slug, content) do
    case fetch_existing(store, slug) do
      {:ok, existing_content, existing_embedding} when existing_content == content ->
        {:ok, existing_embedding}

      _ ->
        Embeddings.embed(content)
    end
  end

  defp fetch_existing(store, slug) do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
      "SELECT content, embedding FROM entries WHERE slug = ?1 AND store = ?2"
    )

    :ok = Exqlite.Sqlite3.bind(stmt, [slug, store])

    result =
      case Exqlite.Sqlite3.step(db, stmt) do
        {:row, [content, blob]} when not is_nil(blob) ->
          {:ok, content, :erlang.binary_to_term(blob)}

        _ ->
          :not_found
      end

    :ok = Exqlite.Sqlite3.release(db, stmt)
    result
  end

  defp upsert_entry(store, slug, label, content, embedding, branch, confidence) do
    db = State.db()
    blob = {:blob, :erlang.term_to_binary(embedding)}
    now = DateTime.utc_now() |> DateTime.to_iso8601()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, """
      INSERT INTO entries (slug, store, label, content, embedding, model, branch, confidence, created_at, updated_at)
      VALUES (?1, ?2, ?3, ?4, ?5, ?6, ?7, ?8, ?9, ?9)
      ON CONFLICT(slug, store) DO UPDATE SET
        label = excluded.label,
        content = excluded.content,
        embedding = excluded.embedding,
        model = excluded.model,
        branch = COALESCE(excluded.branch, entries.branch),
        confidence = COALESCE(excluded.confidence, entries.confidence),
        updated_at = excluded.updated_at
    """)

    :ok = Exqlite.Sqlite3.bind(stmt, [
      slug, store, label, content, blob, Embeddings.model(),
      branch, confidence, now
    ])

    :done = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    :ok
  end

  # Removes a single entry by label from the given store.
  def forget(store, label) do
    slug = slugify(label)

    if entry_exists?(store, slug) do
      exec("DELETE FROM entries WHERE slug = ?1 AND store = ?2", [slug, store])
      :ok
    else
      {:error, "[not found] #{store} :: #{label}"}
    end
  end

  # Moves one or more memories from one store to another. Identifiers may be
  # given as slugs (as printed by recall) or as labels; both are slugified, so
  # the two are interchangeable. A move is a pure store-retag: the embedding is
  # content-derived, so a moved memory keeps matching in recall with no reindex,
  # and timestamps are left untouched so the move does not reset staleness.
  # Refuses to overwrite -- a slug already present in the destination blocks the
  # move, since the (slug, store) primary key would collide. Everything is
  # validated before anything is written. Returns {:ok, slugs} with the moved
  # slugs, or {:error, reason}.
  def move(src, dest, idents) do
    slugs = idents |> Enum.map(&slugify/1) |> Enum.uniq()

    cond do
      src == dest ->
        {:error, "Source and destination are the same store: '#{src}'."}

      not store_exists?(src) ->
        {:error, "Store '#{src}' does not exist."}

      not store_exists?(dest) ->
        {:error, "Store '#{dest}' does not exist."}

      true ->
        missing = Enum.reject(slugs, &entry_exists?(src, &1))
        collisions = Enum.filter(slugs, &entry_exists?(dest, &1))

        cond do
          missing != [] ->
            {:error, "Not found in '#{src}': #{Enum.join(missing, ", ")}"}

          collisions != [] ->
            {:error, "Already present in '#{dest}' (refusing to overwrite): #{Enum.join(collisions, ", ")}"}

          true ->
            move_entries(src, dest, slugs)
            {:ok, slugs}
        end
    end
  end

  # Retags the store column for each slug, wrapped in a single transaction so a
  # partial batch never commits. Only the store changes; embedding, model,
  # branch, confidence, and timestamps are preserved.
  defp move_entries(src, dest, slugs) do
    db = State.db()
    :ok = Exqlite.Sqlite3.execute(db, "BEGIN")

    try do
      {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
        "UPDATE entries SET store = ?1 WHERE store = ?2 AND slug = ?3"
      )

      Enum.each(slugs, fn slug ->
        :ok = Exqlite.Sqlite3.bind(stmt, [dest, src, slug])
        :done = Exqlite.Sqlite3.step(db, stmt)
      end)

      :ok = Exqlite.Sqlite3.release(db, stmt)
      :ok = Exqlite.Sqlite3.execute(db, "COMMIT")
      :ok
    rescue
      e ->
        Exqlite.Sqlite3.execute(db, "ROLLBACK")
        reraise e, __STACKTRACE__
    end
  end

  # Fetches embeddings across multiple stores for cross-store search.
  # When branch is non-nil, includes entries matching that branch OR
  # entries with no branch (project-wide). When nil, returns all entries.
  defp fetch_all_embeddings(stores, branch) do
    placeholders = stores |> Enum.with_index(1) |> Enum.map(fn {_, i} -> "?#{i}" end) |> Enum.join(", ")

    {sql, params} =
      if branch do
        n = length(stores) + 1

        {"SELECT slug, content, embedding, store, branch, confidence FROM entries " <>
         "WHERE embedding IS NOT NULL AND store IN (#{placeholders}) " <>
         "AND (branch IS NULL OR branch = ?#{n})",
         stores ++ [branch]}
      else
        {"SELECT slug, content, embedding, store, branch, confidence FROM entries " <>
         "WHERE embedding IS NOT NULL AND store IN (#{placeholders})",
         stores}
      end

    {:ok, query(sql, params)}
  end

  # Runs a SELECT across entries in a single store. Query fragments are safe
  # here because columns are always hardcoded literals from callers, never
  # interpolated from user input.
  defp fetch_entries(store, select_columns) do
    {:ok, query("SELECT #{select_columns} FROM entries WHERE store = ?1", [store])}
  end

  defp reindex_entries(store, rows) do
    db = State.db()
    model = Embeddings.model()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
      "UPDATE entries SET embedding = ?1, model = ?2 WHERE slug = ?3 AND store = ?4"
    )

    Enum.each(rows, fn [slug, content] ->
      App.info("Reindexing '#{slug}'...")
      {:ok, embedding} = Embeddings.embed(content)
      blob = {:blob, :erlang.term_to_binary(embedding)}
      :ok = Exqlite.Sqlite3.bind(stmt, [blob, model, slug, store])
      :done = Exqlite.Sqlite3.step(db, stmt)
    end)

    :ok = Exqlite.Sqlite3.release(db, stmt)
    :ok
  end

  # Executes a write statement (INSERT/UPDATE/DELETE) with bound params
  defp exec(sql, params) do
    db = State.db()
    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, sql)
    :ok = Exqlite.Sqlite3.bind(stmt, params)
    :done = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    :ok
  end

  # Runs a SELECT query and returns all rows as a list of lists.
  defp query(sql, params \\ []) do
    db = State.db()
    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, sql)
    :ok = Exqlite.Sqlite3.bind(stmt, params)
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    rows
  end

  # Returns true if the query matches at least one row.
  defp exists?(sql, params) do
    db = State.db()
    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, sql)
    :ok = Exqlite.Sqlite3.bind(stmt, params)
    result = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    match?({:row, _}, result)
  end

  # Formats a store/branch scope tag, e.g. "[mystore]" or "[mystore:main]".
  def format_scope(store, nil), do: "[#{store}]"
  def format_scope(store, branch), do: "[#{store}:#{branch}]"

  # Builds a metadata string from a list of {value, formatter} pairs.
  # Nil values are skipped. Returns empty string if no values are present.
  def format_meta(pairs) do
    pairs
    |> Enum.reject(fn {v, _} -> is_nil(v) end)
    |> Enum.map(fn {v, fmt} -> fmt.(v) end)
    |> Enum.join(" | ")
  end

  # Dumps all entries for the given stores, sorted by store (global first)
  # then by updated_at. Returns a list of maps with full metadata.
  def dump(stores) do
    placeholders = stores |> Enum.with_index(1) |> Enum.map(fn {_, i} -> "?#{i}" end) |> Enum.join(", ")

    query("""
      SELECT store, label, content, branch, confidence, created_at, updated_at
      FROM entries
      WHERE store IN (#{placeholders})
      ORDER BY
        CASE WHEN store = '#{@global_store}' THEN 0 ELSE 1 END,
        store,
        updated_at
    """, stores)
    |> Enum.map(fn [store, label, content, branch, confidence, created_at, updated_at] ->
      %Entry{
        store: store, label: label, content: content, branch: branch,
        confidence: confidence, created_at: created_at, updated_at: updated_at
      }
    end)
  end

  # Finds entries whose embeddings are unusually similar to each other,
  # suggesting they may be duplicates or candidates for consolidation.
  #
  # Rather than using a fixed similarity threshold (which would be
  # model-dependent), we compute all pairwise similarity scores, then
  # use z-score outlier detection: pairs scoring more than `sensitivity`
  # standard deviations above the mean are flagged. This adapts to the
  # actual score distribution regardless of model quality.
  #
  # sensitivity=1.5 catches the upper ~7% of pairs (moderate).
  # sensitivity=1.0 is more aggressive (~16%), 2.0 is stricter (~2%).
  def find_duplicates(store, sensitivity \\ 1.5) do
    with {:ok, rows} <- fetch_entries(store, "slug, label, embedding") do
      entries =
        Enum.map(rows, fn [slug, label, blob] ->
          %{slug: slug, label: label, embedding: :erlang.binary_to_term(blob)}
        end)
      pairs =
        for a <- entries, b <- entries, a.slug < b.slug do
          {a, b}
        end

      if pairs == [] do
        {:ok, []}
      else
        # Compute all pairwise similarity scores in parallel
        scored =
          pairs
          |> Task.async_stream(
            fn {a, b} ->
              score = Embeddings.tensor_similarity(a.embedding, b.embedding)
              {score, a.label, b.label}
            end,
            max_concurrency: System.schedulers_online(),
            ordered: false
          )
          |> Enum.map(fn {:ok, result} -> result end)

        # Compute mean and stddev of score distribution
        scores = Enum.map(scored, &elem(&1, 0))
        {mean, stddev} = mean_and_stddev(scores)
        threshold = mean + sensitivity * stddev

        App.debug("Duplicate detection: mean=#{Float.round(mean, 4)}, " <>
          "stddev=#{Float.round(stddev, 4)}, threshold=#{Float.round(threshold, 4)}")

        results =
          scored
          |> Enum.filter(fn {score, _, _} -> score >= threshold end)
          |> Enum.sort_by(&elem(&1, 0), :desc)

        {:ok, results}
      end
    end
  end

  defp mean_and_stddev(values) do
    n = length(values)
    mean = Enum.sum(values) / n

    variance =
      values
      |> Enum.map(fn v -> (v - mean) * (v - mean) end)
      |> Enum.sum()
      |> Kernel./(n)

    {mean, :math.sqrt(variance)}
  end

  def reindex(store) do
    with {:ok, rows} <- fetch_entries(store, "slug, content"),
         :ok <- reindex_entries(store, rows) do
      App.info("Reindex complete. #{length(rows)} entries updated.")
      :ok
    end
  end

  # Strips the "# Label\n\n" heading that write() prepends so callers can
  # apply their own heading hierarchy. Splits on the blank-line separator
  # between heading and body rather than assuming a specific newline count.
  def strip_content_heading(content) do
    case String.split(content, "\n\n", parts: 2) do
      ["# " <> _, rest] -> rest
      _ -> content
    end
  end

  def slugify(label) do
    label
    |> String.trim()
    |> String.downcase()
    |> String.replace(" - ", "-_-")
    |> String.replace(~r/[^a-z0-9\s_-]/, "")
    |> String.replace(~r/\s+/, "-")
  end
end

#-------------------------------------------------------------------------------
# Setup command - configures engram for a project directory
#-------------------------------------------------------------------------------
defmodule Setup do
  @engram_permission "mcp__engram"
  @gitignore_entries [".mcp.json", ".claude/", ".pi/", "opencode.json", ".opencode/"]

  # Backend definitions: label, the file ops to plan/execute, and how to build
  # the MCP server entry for each tool's config format.
  @backends %{
    claude: %{
      label: "Claude Code",
      mcp_entry_fn: :mcp_entry,
      ops: [
        mcp_json: ".mcp.json",
        instructions: {".claude/CLAUDE.md", "example-claude.md", "mcp__engram__"},
        settings: {".claude/settings.local.json", "example-hooks.json"},
      ]
    },
    opencode: %{
      label: "OpenCode",
      mcp_entry_fn: :opencode_mcp_entry,
      ops: [
        opencode_json: "opencode.json",
        instructions: {".opencode/instructions/engram.md", "example-opencode.md", "engram_remember"},
        plugin: {".opencode/plugins/engram.ts", "engram-plugin.ts"},
      ]
    },
    pi: %{
      label: "pi",
      mcp_entry_fn: nil,
      ops: [
        pi_extension: {".pi/extensions/engram.ts", "pi-extension.ts"},
      ]
    },
  }

  #-----------------------------------------------------------------------------
  # Main entry point
  #-----------------------------------------------------------------------------
  def run(engram_path) do
    cwd = File.cwd!()
    engram_dir = Path.dirname(engram_path)

    mode = prompt_setup_mode()
    store_names = prompt_stores()
    backend = @backends[mode]

    # Read source templates once at the top
    sources = read_sources(engram_dir, backend)

    # Plan each file operation and collect results
    plans =
      backend.ops
      |> Keyword.keys()
      |> Enum.map(&plan_op(&1, backend.ops[&1], engram_path, store_names, cwd, engram_dir, sources))

    store_plan = plan_stores(store_names)
    gitignore_plan = plan_gitignore(cwd)

    # Print summary
    print_summary(cwd, backend.label, store_names, store_plan, plans, gitignore_plan, mode)

    IO.write(:standard_error, "Proceed? [y/N] ")

    case IO.read(:stdio, :line) do
      line when is_binary(line) ->
        if String.trim(line) |> String.downcase() == "y" do
          execute_stores(store_plan)
          Enum.each(plans, &execute_op/1)
          execute_gitignore(cwd, gitignore_plan)
          App.info("Done. Restart #{backend.label} to pick up the new configuration.")
        else
          App.info("Cancelled.")
        end

      _ ->
        App.info("Cancelled.")
    end
  end

  #-----------------------------------------------------------------------------
  # Source file loading (shared across all ops)
  #-----------------------------------------------------------------------------
  defp read_sources(engram_dir, backend) do
    backend.ops
    |> Enum.reduce(%{}, fn {_key, spec}, acc ->
      src = source_from_spec(spec)
      if src && !Map.has_key?(acc, src) do
        full_path = Path.join(engram_dir, src)
        unless File.exists?(full_path) do
          App.fatal("Missing #{full_path} - is the engram installation intact?")
        end
        content = File.read!(full_path)
        Map.put(acc, src, content)
      else
        acc
      end
    end)
  end

  # Extracts the source filename from an op spec, if any.
  defp source_from_spec({_, source, _marker}), do: source
  defp source_from_spec({_, source}), do: source
  defp source_from_spec(_), do: nil

  #-----------------------------------------------------------------------------
  # Planning -- each op type has a plan function that returns:
  #   %{path: target_path(s), summary: string, action: atom, extra: term}
  #-----------------------------------------------------------------------------
  defp plan_op(:mcp_json, path, engram_path, store_names, cwd, _engram_dir, _sources) do
    full_path = Path.join(cwd, path)

    if File.exists?(full_path) do
      case File.read!(full_path) |> Jason.decode() do
        {:ok, existing} ->
          if get_in(existing, ["mcpServers", "engram"]) do
            %{path: full_path, summary: "update existing engram entry", action: :update, config_path: path}
          else
            %{path: full_path, summary: "add engram to existing file", action: :update, config_path: path}
          end

        {:error, _} ->
          App.fatal("#{full_path} contains invalid JSON")
      end
    else
      %{path: full_path, summary: "create", action: :create, config_path: path}
    end
    |> Map.put(:config_path, path)
    |> then(&Map.put(&1, :extra, %{engram_path: engram_path, store_names: store_names, entry_fn: :mcp_entry}))
  end

  defp plan_op(:opencode_json, path, engram_path, store_names, cwd, _engram_dir, _sources) do
    full_path = Path.join(cwd, path)

    if File.exists?(full_path) do
      case File.read!(full_path) |> Jason.decode() do
        {:ok, existing} ->
          if get_in(existing, ["mcp", "engram"]) do
            %{path: full_path, summary: "update existing engram entry", action: :update, config_path: path}
          else
            %{path: full_path, summary: "add engram to existing file", action: :update, config_path: path}
          end

        {:error, _} ->
          App.fatal("#{full_path} contains invalid JSON")
      end
    else
      %{path: full_path, summary: "create", action: :create, config_path: path}
    end
    |> Map.put(:extra, %{engram_path: engram_path, store_names: store_names, entry_fn: :opencode_mcp_entry})
  end

  defp plan_op(:instructions, {path, source, marker}, _engram_path, _store_names, cwd, _engram_dir, sources) do
    full_path = Path.join(cwd, path)

    if File.exists?(full_path) do
      content = File.read!(full_path)

      if String.contains?(content, marker) do
        %{path: full_path, summary: "skip (already configured)", action: :skip}
      else
        %{path: full_path, summary: "update", action: :update, source_content: Map.get(sources, source)}
      end
    else
      %{path: full_path, summary: "create", action: :create, source_content: Map.get(sources, source)}
    end
  end

  defp plan_op(:settings, {path, source}, _engram_path, _store_names, cwd, _engram_dir, sources) do
    full_path = Path.join(cwd, path)
    dir = Path.dirname(full_path)
    hooks = Map.get(sources, source) |> Jason.decode!()

    cond do
      File.exists?(full_path) ->
        case File.read!(full_path) |> Jason.decode() do
          {:ok, existing} ->
            has_hooks = has_engram_hooks?(existing)
            has_perm = has_engram_permission?(existing)

            cond do
              has_hooks and has_perm ->
                %{path: full_path, summary: "skip (already configured)", action: :skip}

              has_hooks ->
                %{path: full_path, summary: "add engram permission", action: :update, extra: %{hooks: hooks, merge_hooks: false}}

              has_perm ->
                %{path: full_path, summary: "add engram hooks", action: :update, extra: %{hooks: hooks, merge_hooks: true}}

              true ->
                %{path: full_path, summary: "add engram hooks and permission", action: :update, extra: %{hooks: hooks, merge_hooks: true}}
            end

          {:error, _} ->
            App.fatal("#{full_path} contains invalid JSON")
        end

      File.dir?(dir) ->
        %{path: full_path, summary: "create", action: :create, extra: %{hooks: hooks, merge_hooks: true}}

      true ->
        %{path: full_path, summary: "create .claude/ directory and file", action: :create, extra: %{hooks: hooks, merge_hooks: true}}
    end
  end

  defp plan_op(:plugin, {path, source}, _engram_path, _store_names, cwd, engram_dir, _sources) do
    full_path = Path.join(cwd, path)

    if File.exists?(full_path) do
      %{path: full_path, summary: "skip (already deployed)", action: :skip}
    else
      %{path: full_path, summary: "create", action: :create, extra: %{source_path: Path.join(engram_dir, source)}}
    end
  end

  defp plan_op(:pi_extension, {path, source}, _engram_path, _store_names, cwd, engram_dir, _sources) do
    full_path = Path.join(cwd, path)
    source_path = Path.join(engram_dir, source)

    cond do
      not File.exists?(source_path) ->
        %{path: full_path, summary: "source not found", action: :skip}

      File.exists?(full_path) ->
        real_target =
          case File.read_link(full_path) do
            {:ok, link} -> link
            _ -> :not_link
          end

        if real_target == "../../pi-extension.ts" do
          %{path: full_path, summary: "already linked", action: :skip}
        else
          %{path: full_path, summary: "update symlink", action: :link, extra: %{source_path: source_path}}
        end

      true ->
        %{path: full_path, summary: "create symlink", action: :link, extra: %{source_path: source_path}}
    end
  end

  #-----------------------------------------------------------------------------
  # Shared planning (mode-independent)
  #-----------------------------------------------------------------------------
  defp plan_stores(names) do
    all_needed = Enum.uniq(names ++ ["global"])

    existing =
      case Store.list_stores() do
        {:ok, s} -> s
        _ -> []
      end

    to_create = all_needed -- existing
    already = all_needed -- to_create

    parts = []
    parts = if to_create != [], do: parts ++ ["create #{Enum.join(to_create, ", ")}"], else: parts
    parts = if already != [], do: parts ++ ["#{Enum.join(already, ", ")} already exist"], else: parts

    %{summary: Enum.join(parts, "; "), to_create: to_create}
  end

  defp plan_gitignore(cwd) do
    gitignore_path = Path.join(cwd, ".gitignore")

    if not in_git_repo?() do
      %{summary: "skip (not a git repo)", action: :skip}
    else
      needed = Enum.reject(@gitignore_entries, &git_ignored?/1)

      case {File.exists?(gitignore_path), needed} do
        {_, []} -> %{summary: "skip (already ignored)", action: :skip}
        {true, entries} -> %{summary: "append #{Enum.join(entries, " and ")}", action: :append, path: gitignore_path, entries: entries}
        {false, _} -> %{summary: "create", action: :create, path: gitignore_path}
      end
    end
  end

  #-----------------------------------------------------------------------------
  # Execution -- dispatches on action and op content
  #-----------------------------------------------------------------------------
  defp execute_op(%{action: :skip}), do: :ok

  # MCP JSON config (Claude Code .mcp.json or OpenCode opencode.json)
  defp execute_op(%{action: :create, config_path: path} = plan) do
    make_config(path, plan.extra)
  end

  defp execute_op(%{action: :update, config_path: path} = plan) do
    existing = File.read!(plan.path) |> Jason.decode!()
    updated = merge_config(path, existing, plan.extra)
    write_json(plan.path, updated)
  end

  # Settings (Claude Code settings.local.json) -- merge hooks and permissions
  defp execute_op(%{action: action, extra: %{hooks: hooks} = extra} = plan)
       when action in [:create, :update] do
    File.mkdir_p!(Path.dirname(plan.path))
    execute_settings_merge(plan.path, hooks, extra.merge_hooks)
  end

  # Instructions (markdown templates) -- write the source template
  defp execute_op(%{action: action, source_content: content} = plan)
       when action in [:create, :update] do
    dir = Path.dirname(plan.path)
    File.mkdir_p!(dir)
    File.write!(plan.path, content)
  end

  # Plugin file copy
  defp execute_op(%{action: :create, extra: %{source_path: src}} = plan) do
    dir = Path.dirname(plan.path)
    File.mkdir_p!(dir)
    File.cp!(src, plan.path)
  end

  # Symlink (pi extension)
  defp execute_op(%{action: :link} = plan) do
    dir = Path.dirname(plan.path)
    File.mkdir_p!(dir)

    if File.exists?(plan.path) do
      File.rm!(plan.path)
    end

    target = relative_symlink_target(plan.path, plan.extra.source_path)
    File.ln_s!(target, plan.path)
  end

  #-----------------------------------------------------------------------------
  # MCP config builders -- shared between planning and execution
  #-----------------------------------------------------------------------------
  defp make_config(".mcp.json", extra) do
    config = %{"mcpServers" => %{"engram" => mcp_entry(extra.engram_path, extra.store_names)}}
    write_json(Path.join(File.cwd!(), ".mcp.json"), config)
  end

  defp make_config("opencode.json", extra) do
    config = %{
      "mcp" => %{"engram" => opencode_mcp_entry(extra.engram_path, extra.store_names)},
      "instructions" => [".opencode/instructions/engram.md"]
    }
    write_json(Path.join(File.cwd!(), "opencode.json"), config)
  end

  defp merge_config(".mcp.json", existing, extra) do
    put_in(
      existing,
      [Access.key("mcpServers", %{}), "engram"],
      mcp_entry(extra.engram_path, extra.store_names)
    )
  end

  defp merge_config("opencode.json", existing, extra) do
    updated =
      put_in(
        existing,
        [Access.key("mcp", %{}), "engram"],
        opencode_mcp_entry(extra.engram_path, extra.store_names)
      )

    instructions = Map.get(existing, "instructions", [])
    instructions_path = ".opencode/instructions/engram.md"

    if instructions_path in instructions do
      updated
    else
      Map.put(updated, "instructions", instructions ++ [instructions_path])
    end
  end

  # Builds the MCP server entry for Claude Code (.mcp.json). Always appends
  # "global" to the store list.
  defp mcp_entry(engram_path, store_names) do
    args = ["mcp"] ++ store_names ++ ["global"]
    %{"type" => "stdio", "command" => engram_path, "args" => Enum.uniq(args)}
  end

  # Builds the MCP server entry for OpenCode (opencode.json). OpenCode uses
  # "local" transport with a command array instead of separate command + args.
  defp opencode_mcp_entry(engram_path, store_names) do
    command = [engram_path, "mcp"] ++ store_names ++ ["global"]
    %{"type" => "local", "command" => Enum.uniq(command), "enabled" => true}
  end

  #-----------------------------------------------------------------------------
  # Settings merging (Claude Code specific)
  #-----------------------------------------------------------------------------
  defp has_engram_hooks?(settings) do
    hooks = Map.get(settings, "hooks", %{})

    Enum.all?(["SessionStart", "UserPromptSubmit"], fn event ->
      hooks
      |> Map.get(event, [])
      |> Enum.any?(fn group ->
        group
        |> Map.get("hooks", [])
        |> Enum.any?(fn h -> String.contains?(Map.get(h, "command", ""), "[engram]") end)
      end)
    end)
  end

  defp has_engram_permission?(settings) do
    settings
    |> get_in(["permissions", "allow"])
    |> is_list()
    |> then(fn true -> @engram_permission in get_in(settings, ["permissions", "allow"]); false -> false end)
  end

  #-----------------------------------------------------------------------------
  # Shared gitignore
  #-----------------------------------------------------------------------------
  defp execute_gitignore(_cwd, %{action: :skip}), do: :ok

  defp execute_gitignore(cwd, %{action: :create}) do
    File.write!(Path.join(cwd, ".gitignore"), Enum.join(@gitignore_entries, "\n") <> "\n")
  end

  defp execute_gitignore(cwd, %{action: :append} = plan) do
    path = plan.path || Path.join(cwd, ".gitignore")
    content = File.read!(path)
    separator = if String.ends_with?(content, "\n"), do: "", else: "\n"
    File.write!(path, content <> separator <> Enum.join(plan.entries, "\n") <> "\n")
  end

  defp in_git_repo? do
    match?({_, 0}, System.cmd("git", ["rev-parse", "--git-dir"], stderr_to_stdout: true))
  end

  defp git_ignored?(path) do
    match?({_, 0}, System.cmd("git", ["check-ignore", "-q", path], stderr_to_stdout: true))
  end

  #-----------------------------------------------------------------------------
  # Store execution (shared)
  #-----------------------------------------------------------------------------
  defp execute_stores(%{to_create: names}) do
    Enum.each(names, &Store.create/1)
  end

  #-----------------------------------------------------------------------------
  # Summary printing
  #-----------------------------------------------------------------------------
  defp print_summary(cwd, label, store_names, store_plan, plans, gitignore_plan, mode) do
    mcp_stores_label = (store_names ++ ["global"]) |> Enum.join(", ")

    lines =
      plans
      |> Enum.map(fn %{path: p, summary: s} ->
        rel = Path.relative_to(p, cwd)
        "      #{String.pad_trailing(rel, 30)} #{s}"
      end)

    oc_lines = if mode == :opencode, do: lines, else: ["      opencode.*:                   skipped"]
    claude_lines = if mode == :claude, do: lines, else: ["      .claude/*:                    skipped"]
    pi_line = if mode == :pi, do: lines, else: ["      Pi extension:                 (not selected)"]

    IO.puts(:standard_error, """

    engram setup for '#{cwd}' (mode: #{label})

      Stores (MCP):                 #{mcp_stores_label}
      Store changes:                #{store_plan.summary}
    #{Enum.join(oc_lines, "\n")}
    #{Enum.join(claude_lines, "\n")}
      .gitignore:                   #{gitignore_plan.summary}
    #{Enum.join(pi_line, "\n")}
    """)

    if gitignore_plan.action != :skip do
      IO.puts(:standard_error, "  Note: .mcp.json, opencode.json, .claude/, and .opencode/ will be gitignored.")
      IO.puts(:standard_error, "  Remove from .gitignore to share with your team.\n")
    end
  end

  #-----------------------------------------------------------------------------
  # Settings file execution
  #-----------------------------------------------------------------------------
  defp execute_settings_merge(full_path, source_hooks, merge_hooks) do
    if File.exists?(full_path) do
      existing = File.read!(full_path) |> Jason.decode!()
      updated = merge_settings(existing, source_hooks, merge_hooks)
      write_json(full_path, updated)
    else
      settings = merge_settings(%{}, source_hooks, merge_hooks)
      write_json(full_path, settings)
    end
  end

  defp merge_settings(existing, source_hooks, merge_hooks) do
    existing
    |> then(fn s -> if merge_hooks, do: merge_hooks_config(s, source_hooks), else: s end)
    |> merge_permission()
  end

  defp merge_hooks_config(existing, source_hooks) do
    source_hook_map = Map.get(source_hooks, "hooks", %{})
    existing_hooks = Map.get(existing, "hooks", %{})

    merged =
      Enum.reduce(source_hook_map, existing_hooks, fn {event, entries}, acc ->
        existing_entries = Map.get(acc, event, [])

        already_present =
          Enum.any?(existing_entries, fn group ->
            group
            |> Map.get("hooks", [])
            |> Enum.any?(fn h -> String.contains?(Map.get(h, "command", ""), "[engram]") end)
          end)

        if already_present, do: acc, else: Map.put(acc, event, existing_entries ++ entries)
      end)

    Map.put(existing, "hooks", merged)
  end

  defp merge_permission(settings) do
    allow = get_in(settings, ["permissions", "allow"]) || []

    if @engram_permission in allow do
      settings
    else
      put_in(settings, [Access.key("permissions", %{}), Access.key("allow", [])], allow ++ [@engram_permission])
    end
  end

  defp relative_symlink_target(target, source) do
    target_dir = Path.dirname(target)
    source |> Path.absname() |> Path.relative_to(target_dir)
  end

  defp write_json(path, data) do
    File.write!(path, Jason.encode!(data, pretty: true) <> "\n")
  end

  #-----------------------------------------------------------------------------
  # Interactive prompts
  #-----------------------------------------------------------------------------
  defp prompt_setup_mode do
    IO.puts(:standard_error, """
    Which tool do you want to set up?
      [1] Claude Code
      [2] pi
      [3] OpenCode
    """)
    IO.write(:standard_error, "> ")

    case IO.read(:stdio, :line) do
      line when is_binary(line) ->
        case String.trim(line) do
          "1" -> :claude
          "2" -> :pi
          "3" -> :opencode
          _ -> App.fatal("Invalid selection.")
        end

      _ ->
        App.fatal("No input received.")
    end
  end

  defp prompt_stores do
    with :ok <- Store.open_db() do
      existing =
        case Store.list_stores() do
          {:ok, stores} -> stores -- ["global"]
          _ -> []
        end

      if existing != [] do
        IO.puts(:standard_error, "\nExisting stores:")

        Enum.each(existing, fn name ->
          IO.puts(:standard_error, "  - #{name}")
        end)

        IO.puts(:standard_error, "")
      end

      IO.puts(:standard_error, "Enter stores separated by spaces.")
      IO.puts(:standard_error, "Use NEW to create a new store.\n")
      IO.write(:standard_error, "> ")

      case IO.read(:stdio, :line) do
        line when is_binary(line) ->
          parse_store_input(line, existing)

        _ ->
          App.fatal("No input received.")
      end
    else
      {:error, reason} -> App.fatal(reason)
    end
  end

  defp parse_store_input(line, existing) do
    tokens =
      line
      |> String.replace(~r/["']/, "")
      |> String.split()
      |> Enum.map(&String.trim/1)
      |> Enum.reject(&(&1 == ""))

    if tokens == [] do
      App.fatal("No stores specified.")
    end

    names =
      Enum.flat_map(tokens, fn token ->
        if String.upcase(token) == "NEW" do
          [prompt_new_store_name()]
        else
          case Store.validate_name(token) do
            :ok -> [token]
            {:error, reason} -> App.fatal(reason)
          end
        end
      end)

    unknown = names -- existing

    for name <- unknown do
      IO.puts(:standard_error, "  Will create new store '#{name}'")
    end

    Enum.uniq(names)
  end

  defp prompt_new_store_name do
    IO.write(:standard_error, "New store name: ")

    case IO.read(:stdio, :line) do
      line when is_binary(line) ->
        name =
          line
          |> String.replace(~r/["']/, "")
          |> String.trim()

        case Store.validate_name(name) do
          :ok -> name
          {:error, reason} -> App.fatal(reason)
        end

      _ ->
        App.fatal("No input received.")
    end
  end
end

#-------------------------------------------------------------------------------
# Process ARGV
#-------------------------------------------------------------------------------
{flags, argv, invalid} =
  System.argv()
  |> OptionParser.parse_head(
    switches: [
      help: :boolean,
      verbose: :boolean,
    ],
    aliases: [
      h: :help,
      v: :verbose,
    ]
  )

# Reject unrecognized flags
if invalid != [] do
  bad = Enum.map(invalid, fn {k, _} -> k end)
  App.error("Unrecognized flags: #{Enum.join(bad, ", ")}")
  App.help(1)
end

flags = Map.new(flags)

# Override logger level if --verbose is set
if flags[:verbose] do
  :logger.set_primary_config(:level, :debug)
end

State.start_link()

#-------------------------------------------------------------------------------
# Dispatch
#-------------------------------------------------------------------------------
if flags[:help] do
  App.help(0)
end

case argv do
  ["list-stores"] ->
    case Store.list_stores() do
      {:ok, []} ->
        IO.puts("No stores found. Use 'create <name>' to create one.")

      {:ok, stores} ->
        IO.puts("Existing stores:")
        stores |> Enum.each(&IO.puts("  - #{&1}"))
    end

  ["list", store] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([store]) do
      case Store.list_entries(store) do
        [] ->
          IO.puts(:standard_error, "No memories in '#{store}'.")

        entries ->
          Enum.each(entries, fn entry ->
            scope = Store.format_scope(store, entry.branch)

            meta =
              Store.format_meta([
                {entry.confidence, &"c:#{&1}"},
                {entry.updated_at, & &1}
              ])

            line =
              if meta == "", do: "#{scope} #{entry.label}", else: "#{scope} #{entry.label} (#{meta})"

            IO.puts(line)
          end)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["create", name] ->
    case Store.create(name) do
      {:ok, name} ->
        IO.puts(:standard_error, """
        Created store '#{name}'.

        To start the MCP server (with optional global store):
          engram mcp #{name}
          engram mcp #{name} global

        To add to .mcp.json (recommended):
          {
            "mcpServers": {
              "engram": {
                "type": "stdio",
                "command": "engram",
                "args": ["mcp", "#{name}", "global"]
              }
            }
          }
        """)

      {:error, reason} ->
        App.error(reason)
    end

  ["remove", name] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([name]) do
      IO.write(:standard_error, "Remove store '#{name}'? This cannot be undone. [y/N] ")

      case IO.read(:stdio, :line) do
        line when is_binary(line) ->
          if String.trim(line) |> String.downcase() == "y" do
            case Store.remove_store(name) do
              :ok -> App.info("Removed store '#{name}'")
              {:error, reason} -> App.error(reason)
            end
          else
            App.info("Cancelled.")
          end

        _ ->
          App.info("Cancelled.")
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["find-duplicates" | rest] ->
    {dup_flags, dup_argv, dup_invalid} =
      OptionParser.parse(rest,
        switches: [header: :boolean],
        aliases: [H: :header]
      )

    cond do
      dup_invalid != [] ->
        bad = Enum.map(dup_invalid, fn {k, _} -> k end)
        App.fatal("Unrecognized flags: #{Enum.join(bad, ", ")}")

      length(dup_argv) != 1 ->
        App.fatal("Usage: engram find-duplicates [--header|-H] <name>")

      true ->
        [name] = dup_argv

        with :ok <- Store.open_db(),
             :ok <- Store.validate_stores([name]) do
          Embeddings.ensure_started()

          case Store.find_duplicates(name) do
            {:ok, pairs} ->
              if dup_flags[:header] do
                IO.puts("score\ta\tb")
              end

              if pairs == [] do
                IO.puts(:stderr, "No unusually similar memories found.")
              else
                Enum.each(pairs, fn {score, label_a, label_b} ->
                  IO.puts("#{Float.round(score, 3)}\t#{label_a}\t#{label_b}")
                end)
              end

            {:error, reason} ->
              App.error(reason)
          end
        else
          {:error, reason} ->
            App.fatal(reason)
        end
    end

  ["reindex", name] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([name]) do
      Nx.global_default_backend(EXLA.Backend)
      Embeddings.start()

      case Store.reindex(name) do
        :ok -> :ok
        {:error, reason} -> App.error(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["forget", store, label] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([store]) do
      case Store.forget(store, label) do
        :ok ->
          IO.puts("[forgotten] #{store} :: #{label}")

        {:error, reason} ->
          App.error(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["move", src, dest | slugs] when slugs != [] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([src, dest]) do
      case Store.move(src, dest, slugs) do
        {:ok, moved} ->
          Enum.each(moved, fn slug ->
            IO.puts("[moved] #{src} -> #{dest} :: #{slug}")
          end)

        {:error, reason} ->
          App.error(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["show", store, slug] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores([store]) do
      case Store.read(store, slug) do
        {:ok, entry} ->
          scope = Store.format_scope(store, entry.branch)

          meta =
            Store.format_meta([
              {entry.confidence, &"confidence:#{&1}"},
              {entry.created_at, &"created:#{&1}"},
              {entry.updated_at, &"updated:#{&1}"}
            ])

          content = Store.strip_content_heading(entry.content)
          IO.puts("# #{scope} #{entry.label}")
          IO.puts("")
          if meta != "", do: IO.puts("_#{meta}_\n")
          IO.puts(content)

        {:error, reason} ->
          App.error(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["dump" | stores] when stores != [] ->
    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores(stores) do
      entries = Store.dump(stores)

      entries
      |> Enum.chunk_by(& &1.store)
      |> Enum.each(fn group ->
        store_name = hd(group).store
        IO.puts("# #{store_name}\n")

        Enum.each(group, fn entry ->
          branch_tag = if entry.branch, do: " [#{entry.branch}]", else: ""

          meta =
            Store.format_meta([
              {entry.confidence, &"confidence:#{&1}"},
              {entry.updated_at, &"updated:#{&1}"}
            ])

          content = Store.strip_content_heading(entry.content)
          IO.puts("## #{entry.label}#{branch_tag}")
          IO.puts("")
          if meta != "", do: IO.puts("_#{meta}_\n")
          IO.puts(content)
          IO.puts("\n---\n")
        end)
      end)
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["remember", store | rest] ->
    {flags, _, invalid} =
      OptionParser.parse(rest,
        switches: [
          label: :string,
          content: :string,
          overwrite: :boolean,
          branch: :string,
          confidence: :integer
        ]
      )

    if invalid != [] do
      bad = Enum.map(invalid, fn {k, _} -> k end)
      App.fatal("Unrecognized flags: #{Enum.join(bad, ", ")}")
    end

    label = flags[:label]
    content = flags[:content]

    cond do
      is_nil(label) ->
        App.fatal("Usage: engram remember <store> --label <label> --content <content>")

      is_nil(content) ->
        App.fatal("Usage: engram remember <store> --label <label> --content <content>")

      true ->
        with :ok <- Store.open_db(),
             :ok <- Store.validate_stores([store]) do
          Embeddings.ensure_started()

          opts = [
            overwrite: flags[:overwrite] || false,
            branch: flags[:branch],
            confidence: flags[:confidence]
          ]

          case Store.write(store, label, content, opts) do
            :ok ->
              IO.puts("[saved] #{store} :: #{label}")

            {:error, reason} ->
              App.error(reason)
          end
        else
          {:error, reason} ->
            App.fatal(reason)
        end
    end

  ["recall" | rest] when rest != [] ->
    {stores, query_words} =
      case Enum.split_while(rest, &(&1 != "--")) do
        {stores, ["--" | words]} when stores != [] and words != [] -> {stores, words}
        _ ->
          App.fatal("Usage: engram recall <store> [<store> ...] -- <query>")
      end

    query = Enum.join(query_words, " ")

    with :ok <- Store.open_db(),
         :ok <- Store.validate_stores(stores) do
      State.stores(stores)
      Nx.global_default_backend(EXLA.Backend)
      Embeddings.start()

      case Store.search(query) do
        {:ok, []} ->
          IO.puts("No results.")

        {:ok, results} ->
          Enum.each(results, fn {score, entry} ->
            scope = Store.format_scope(entry.store, entry.branch)

            confidence =
              if entry.confidence do
                " c:#{String.pad_leading(to_string(entry.confidence), 2, "0")}"
              else
                ""
              end

            score_str = :io_lib.format("~.3f", [score]) |> IO.iodata_to_binary()
            IO.puts("#{score_str} #{scope}#{confidence} #{entry.slug}")
          end)

        {:error, reason} ->
          App.error(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  ["setup"] ->
    Setup.run(App.script_path())

  ["mcp" | rest] when rest != [] ->
    with :ok <- Store.open_db() do
      # --all loads every store in the database; explicit names are validated
      stores =
        if "--all" in rest do
          case Store.list_stores() do
            {:ok, all} -> all
            _ -> App.fatal("Failed to list stores")
          end
        else
          rest
        end

      if stores == [], do: App.fatal("No stores found")

      with :ok <- Store.validate_stores(stores) do
        State.stores(stores)
        App.info("Serving stores: #{Enum.join(stores, ", ")}")
        Nx.global_default_backend(EXLA.Backend)
        Embeddings.start()
        McpServer.run()
      else
        {:error, reason} -> App.fatal(reason)
      end
    else
      {:error, reason} ->
        App.fatal(reason)
    end

  _ ->
    App.help(1)
end
