defmodule StoreMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "remember",
      description: "Persists a piece of information in the current store. " <>
        "Before writing, always use recall to check for existing similar memories. " <>
        "If one exists, read it and use overwrite: true to update it rather than creating a duplicate. " <>
        "Each memory should be focused on a single topic. Write memories as reference material " <>
        "for a future instance of yourself with zero context about the current session.",
      inputSchema: %{
        type: "object",
        required: ["label", "content"],
        properties: %{
          label: %{
            type: "string",
            description: "A short, descriptive title for the memory. Used for deduplication (memories with the same label in the same store are considered the same entry)."
          },
          content: %{
            type: "string",
            description: "The information to remember. Should be self-contained and understandable without session context."
          },
          overwrite: %{
            type: "boolean",
            description: "Set to true to overwrite an existing memory with the same label. Required when updating an existing memory."
          },
          store: %{
            type: "string",
            description: "Which store to write to (defaults to the primary project store)"
          },
          branch: %{
            type: "string",
            description: "Git branch this memory is scoped to. Omit for project-wide memories that apply regardless of branch. " <>
              "Set to the current branch name for context that is only relevant to work on that branch (e.g. feature design decisions, WIP notes, branch-specific workarounds)."
          },
          confidence: %{
            type: "integer",
            description: "How well-established this observation is, on a scale of 1-10. " <>
              "1-2: single ambiguous signal. 3-4: weak pattern, 1-2 consistent signals. " <>
              "5-6: moderate, several consistent signals. 7-8: strong pattern, confirmed across contexts. " <>
              "9: explicitly stated or consistently demonstrated. 10: definitional, declared as a hard constraint. " <>
              "When updating an existing memory, adjust the confidence based on accumulated evidence."
          }
        }
      }
    }
  end

  @impl true
  def call(%{"label" => _label, "data" => _data}) do
    {:error, "Invalid argument: use 'content' (not 'data') to pass the memory text. " <>
      "Required fields: label (string), content (string). " <>
      "Optional: store, branch, confidence, overwrite."}
  end

  def call(%{"label" => label, "content" => data} = args) do
    with {:ok, store} <- State.require_store(args) do
      overwrite = Map.get(args, "overwrite", false)
      branch = Map.get(args, "branch")
      confidence = Map.get(args, "confidence")

      opts = [overwrite: overwrite, branch: branch, confidence: confidence]

      case Store.write(store, label, data, opts) do
        :ok -> {:ok, "[saved] #{store} :: #{label}"}
        {:error, reason} -> {:error, reason}
      end
    end
  end

  def call(_) do
    {:error, "Missing or invalid arguments. Required: label (string), content (string). " <>
      "Optional: store, branch, confidence, overwrite."}
  end
end

defmodule ListMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "list",
      description: "Lists all memory labels in a store with their metadata. " <>
        "Use this at session startup to see what's available without pulling everything into context.",
      inputSchema: %{
        type: "object",
        properties: %{
          store: %{
            type: "string",
            description: "Which store to list (defaults to the primary project store)"
          }
        }
      }
    }
  end

  @impl true
  def call(args) do
    with {:ok, store} <- State.require_store(args) do
      Store.list_entries(store)
      |> Enum.map(&format_entry/1)
      |> Enum.join("\n")
      |> then(&{:ok, &1})
    end
  end

  defp format_entry(%Store.Entry{label: label, store: store, branch: branch, confidence: confidence, updated_at: updated_at}) do
    scope = Store.format_scope(store, branch)

    meta =
      Store.format_meta([
        {confidence, &"c:#{&1}"},
        {updated_at, & &1}
      ])

    if meta == "", do: "#{scope} #{label}", else: "#{scope} #{label} (#{meta})"
  end
end

defmodule RecallMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "recall",
      description: "Recalls information from all active stores relevant to a query. " <>
        "Searches semantically across all stores in this session. " <>
        "When a branch is specified, returns both branch-specific and project-wide (unscoped) memories.",
      inputSchema: %{
        type: "object",
        required: ["query"],
        properties: %{
          query: %{
            type: "string",
            description: "A query to recall relevant information for"
          },
          branch: %{
            type: "string",
            description: "Filter results to this branch plus project-wide (unscoped) memories. " <>
              "Omit to search all memories regardless of branch."
          }
        }
      }
    }
  end

  @impl true
  def call(%{"query" => query} = args) do
    branch = Map.get(args, "branch")
    opts = if branch, do: [branch: branch], else: []

    with {:ok, results} <- Store.search(query, opts) do
      results
      |> Enum.map(fn {_score, entry} -> format_result(entry) end)
      |> Enum.join("\n\n-----\n\n")
      |> then(&{:ok, &1})
    end
  end

  defp format_result(%Store.Entry{content: content, store: store, branch: branch, confidence: confidence}) do
    meta =
      Store.format_meta([
        {store, &"store:#{&1}"},
        {branch, &"branch:#{&1}"},
        {confidence, &"confidence:#{&1}"}
      ])

    "[#{meta}]\n#{content}"
  end
end

defmodule FindDuplicateMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "find-duplicates",
      description: "Finds memories with unusually similar content that may be candidates for consolidation. " <>
        "Uses statistical outlier detection rather than a fixed threshold, so it adapts to the embedding model's score range.",
      inputSchema: %{
        type: "object",
        properties: %{
          store: %{
            type: "string",
            description: "Which store to check (defaults to the primary project store)"
          },
          sensitivity: %{
            type: "number",
            description: "How many standard deviations above mean to flag (default 1.5). " <>
              "Lower values find more pairs, higher values are stricter."
          }
        }
      }
    }
  end

  @impl true
  def call(args) do
    sensitivity = Map.get(args, "sensitivity", 1.5)

    with {:ok, store} <- State.require_store(args),
         {:ok, pairs} <- Store.find_duplicates(store, sensitivity) do
      if pairs == [] do
        {:ok, "[no duplicates] #{store}"}
      else
        pairs
        |> Enum.map(fn {score, label_a, label_b} ->
          "#{Float.round(score, 3)} | \"#{label_a}\" <-> \"#{label_b}\""
        end)
        |> Enum.join("\n")
        |> then(&{:ok, "[duplicates] #{store}\n#{&1}"})
      end
    end
  end
end

