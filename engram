#!/usr/bin/env elixir

#-------------------------------------------------------------------------------
# Force standard_io to Unicode (UTF-8) mode.
#
# Cursor and other GUI app launchers spawn processes without locale environment
# variables (LANG, LC_ALL, LC_CTYPE). Without them the BEAM defaults to Latin-1
# mode, and IO.write converts non-ASCII codepoints (e.g. em-dashes in stored
# memories) to \x{NNNN} escape sequences instead of their UTF-8 bytes. Those
# escapes are invalid JSON and cause the MCP client to drop the connection.
#-------------------------------------------------------------------------------
:io.setopts(:standard_io, [{:encoding, :unicode}])

# Redirects the default logger handler to stderr so log lines don't pollute
# stdout-bound data streams. Used before and after Mix.install/1 since
# Mix.install starts applications that re-register the handler to stdout.
defmodule LogHelper do
  def to_stderr do
    {:ok, cfg} = :logger.get_handler_config(:default)
    cfg = Map.update!(cfg, :config, &Map.put(&1, :type, :standard_error))
    :ok = :logger.remove_handler(:default)
    :ok = :logger.add_handler(:default, :logger_std_h, cfg)
  end
end

LogHelper.to_stderr()
:ok = :logger.set_primary_config(:level, :info)

#-------------------------------------------------------------------------------
# Install dependencies
#-------------------------------------------------------------------------------
Mix.install([
  {:bumblebee, "~> 0.6"},
  {:exla, "~> 0.9"},
  {:exqlite, "~> 0.27"},
  {:jason, "~> 1.4"},
])

# Mix.install starts applications that re-register the default logger handler
# with stdout as its target. Re-apply the stderr config.
LogHelper.to_stderr()

#-------------------------------------------------------------------------------
# Tool behaviour
#-------------------------------------------------------------------------------
defmodule McpTool do
  @type tool_spec :: %{
    name: binary,
    description: binary,
    inputSchema: map
  }

  @callback spec() :: tool_spec
  @callback call(map) :: {:ok, binary} | {:error, binary}
end

#-------------------------------------------------------------------------------
# MCP Server implementation (stdio)
#-------------------------------------------------------------------------------
defmodule McpServer do
  @jsonrpc_invalid_params -32602

  @service %{
    protocolVersion: "2024-11-05",
    serverInfo: %{name: "engram", version: "0.1.0"},
    capabilities: %{tools: %{}}
  }

  #-----------------------------------------------------------------------------
  # Main loop
  #-----------------------------------------------------------------------------
  def run do
    App.log(:info, "Tools: #{inspect(tools_map(), pretty: true, limit: :infinity)}")
    App.log(:info, "Engram ready")
    loop()
  end

  defp loop do
    case IO.read(:stdio, :line) do
      :eof -> :ok
      "\n" -> loop()
      {:error, reason} -> App.log(:error, "error reading from stdin", reason)

      line ->
        line
        |> String.trim()
        |> Jason.decode()
        |> case do
          {:ok, nil} -> :ok
          {:ok, msg} -> handle_request(msg)
          {:error, reason} -> App.log(:error, "error parsing request", %{input: line, message: reason})
        end

        loop()
    end
  end

  #-----------------------------------------------------------------------------
  # Message handling
  #-----------------------------------------------------------------------------
  # Notifications have no id and receive no response
  defp handle_request(%{"method" => "notifications/" <> _}), do: :ok

  # Requests have an id and always receive a response
  defp handle_request(%{"id" => id, "method" => method} = msg) do
    method
    |> handle_method(msg)
    |> case do
      {:ok, result} -> reply(id, result)
      {:error, code, reason} -> fail(id, code, reason)
      {:tool_error, reason} -> reply(id, %{content: [%{type: "text", text: reason}], isError: true})
    end
  end

  defp handle_method("initialize", _), do: {:ok, @service}
  defp handle_method("ping", _), do: {:ok, %{}}

  defp handle_method("tools/list", _) do
    tools()
    |> Enum.map(& &1.spec())
    |> then(&{:ok, %{tools: &1}})
  end

  defp handle_method("tools/call", %{"params" => %{"name" => name} = params}) do
    tools_map()
    |> Map.get(name)
    |> case do
      nil ->
        {:error, @jsonrpc_invalid_params, "Unknown tool: #{name}"}

      tool ->
        args = Map.get(params, "arguments", %{})

        try do
          case tool.call(args) do
            {:ok, text} -> {:ok, %{content: [%{type: "text", text: text}]}}
            {:error, reason} -> {:tool_error, reason}
          end
        rescue
          e ->
            App.error("Tool '#{name}' crashed", e)
            {:tool_error, "Internal error: #{Exception.message(e)}"}
        end
    end
  end

  defp handle_method(method, _), do: {:error, -32601, "Method not found: #{method}"}

  #-----------------------------------------------------------------------------
  # Communication helpers
  #-----------------------------------------------------------------------------
  defp reply(id, result), do: %{id: id, result: result} |> write()
  defp fail(id, code, message), do: %{id: id, error: %{code: code, message: message}} |> write()

  defp write(%{} = msg) do
    msg
    |> Map.put(:jsonrpc, "2.0")
    |> Jason.encode!()
    |> then(&(&1 <> "\n"))
    |> IO.write()
  end

  #-----------------------------------------------------------------------------
  # Tool discovery
  #-----------------------------------------------------------------------------
  defp tools do
    :code.all_loaded()
    |> Enum.map(&elem(&1, 0))
    |> Enum.filter(&function_exported?(&1, :spec, 0))
    |> Enum.filter(&function_exported?(&1, :call, 1))
  end

  defp tools_map do
    tools()
    |> Enum.map(fn tool -> {tool.spec().name, tool} end)
    |> Map.new()
  end
end

