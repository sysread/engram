#-------------------------------------------------------------------------------
# Tool behaviour
#-------------------------------------------------------------------------------
defmodule McpTool do
  @type tool_spec :: %{
    name: binary,
    description: binary,
    inputSchema: map
  }

  @callback spec() :: tool_spec
  @callback call(map) :: {:ok, binary} | {:error, binary}
end

#-------------------------------------------------------------------------------
# MCP Server implementation (stdio)
#-------------------------------------------------------------------------------
defmodule McpServer do
  @jsonrpc_invalid_params -32602

  @service %{
    protocolVersion: "2024-11-05",
    serverInfo: %{name: "engram", version: "0.1.0"},
    capabilities: %{tools: %{}}
  }

  #-----------------------------------------------------------------------------
  # Main loop
  #-----------------------------------------------------------------------------
  def run do
    App.log(:info, "Tools: #{inspect(tools_map(), pretty: true, limit: :infinity)}")
    App.log(:info, "Engram ready")
    loop()
  end

  defp loop do
    case IO.read(:stdio, :line) do
      :eof -> :ok
      "\n" -> loop()
      {:error, reason} -> App.log(:error, "error reading from stdin", reason)

      line ->
        line
        |> String.trim()
        |> Jason.decode()
        |> case do
          {:ok, nil} -> :ok
          {:ok, msg} -> handle_request(msg)
          {:error, reason} -> App.log(:error, "error parsing request", %{input: line, message: reason})
        end

        loop()
    end
  end

  #-----------------------------------------------------------------------------
  # Message handling
  #-----------------------------------------------------------------------------
  # Notifications have no id and receive no response
  defp handle_request(%{"method" => "notifications/" <> _}), do: :ok

  # Requests have an id and always receive a response
  defp handle_request(%{"id" => id, "method" => method} = msg) do
    method
    |> handle_method(msg)
    |> case do
      {:ok, result} -> reply(id, result)
      {:error, code, reason} -> fail(id, code, reason)
      {:tool_error, reason} -> reply(id, %{content: [%{type: "text", text: reason}], isError: true})
    end
  end

  defp handle_method("initialize", _), do: {:ok, @service}

  defp handle_method("tools/list", _) do
    tools()
    |> Enum.map(& &1.spec())
    |> then(&{:ok, %{tools: &1}})
  end

  defp handle_method("tools/call", %{"params" => %{"name" => name} = params}) do
    tools_map()
    |> Map.get(name)
    |> case do
      nil ->
        {:error, @jsonrpc_invalid_params, "Unknown tool: #{name}"}

      tool ->
        args = Map.get(params, "arguments", %{})

        case tool.call(args) do
          {:ok, text} -> {:ok, %{content: [%{type: "text", text: text}]}}
          {:error, reason} -> {:tool_error, reason}
        end
    end
  end

  #-----------------------------------------------------------------------------
  # Communication helpers
  #-----------------------------------------------------------------------------
  defp reply(id, result), do: %{id: id, result: result} |> write()
  defp fail(id, code, message), do: %{id: id, error: %{code: code, message: message}} |> write()

  defp write(%{} = msg) do
    msg
    |> Map.put(:jsonrpc, "2.0")
    |> Jason.encode!()
    |> then(&(&1 <> "\n"))
    |> IO.write()
  end

  #-----------------------------------------------------------------------------
  # Tool discovery
  #-----------------------------------------------------------------------------
  defp tools do
    :code.all_loaded()
    |> Enum.map(&elem(&1, 0))
    |> Enum.filter(&function_exported?(&1, :spec, 0))
    |> Enum.filter(&function_exported?(&1, :call, 1))
  end

  defp tools_map do
    tools()
    |> Enum.map(fn tool -> {tool.spec().name, tool} end)
    |> Map.new()
  end
end

#-------------------------------------------------------------------------------
# Tools
#-------------------------------------------------------------------------------
defmodule StoreMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "remember",
      description: "Persists a piece of information in the current store",
      inputSchema: %{
        type: "object",
        required: ["label", "data"],
        properties: %{
          label: %{
            type: "string",
            description: "A label for the information to remember"
          },
          data: %{
            type: "string",
            description: "The information to remember"
          },
          overwrite: %{
            type: "boolean",
            description: "Set to true to overwrite an existing memory with the same label"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"label" => label, "data" => data} = args) do
    overwrite = Map.get(args, "overwrite", false)

    case Store.write(label, data, overwrite: overwrite) do
      :ok -> {:ok, "'#{label}' has been remembered"}
      {:error, reason} -> {:error, reason}
    end
  end
end

defmodule ListMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "list",
      description: "Lists all entries in the current store",
      inputSchema: %{
        type: "object",
        properties: %{}
      }
    }
  end

  @impl true
  def call(_) do
    Store.list_entries()
    |> Enum.join("\n")
    |> then(&{:ok, &1})
  end
end

defmodule RecallMemories do
  @behaviour McpTool

  @impl true
  def spec() do
    %{
      name: "recall",
      description: "Recalls information from the current store relevant to a query",
      inputSchema: %{
        type: "object",
        required: ["query"],
        properties: %{
          query: %{
            type: "string",
            description: "A query to recall relevant information for"
          }
        }
      }
    }
  end

  @impl true
  def call(%{"query" => query}) do
    with {:ok, results} <- Store.search(query) do
      results
      |> Enum.map(fn {_score, entry} -> entry end)
      |> Enum.join("\n\n-----\n\n")
      |> then(&{:ok, &1})
    end
  end
end

