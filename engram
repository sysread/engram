defmodule App do
  def help(exit_code \\ 0) do
    IO.puts(:standard_error, """
    SYNOPSIS
      engram <command> [options]

    DESCRIPTION
      engram is a local storage system for LLMs to persist information across interactions.

    OPTIONS
      --help    | -h      Show this help message
      --verbose | -v      Enable verbose output

    COMMANDS
      list                List existing stores
      create  <name>      Create a new store
      remove  <name>      Remove a store
      reindex <name>      Regenerate all embeddings
      mcp     <name>      Start the MCP server with the named store (transport: stdio)

    EXAMPLES
      # Create a new store named "blarg"
      engram create blarg

      # Add blarg to claude
      claude mcp add engram -- path/to/engram mcp blarg

      # Add blarg to ~/.claude.json
      "/Users/jeff.ober/dev/engram": {
        "mcpServers": {
          "engram": {
            "type": "stdio",
            "command": "path/to/engram",
            "args": ["mcp", "blarg"],
            "env": {}
          }
        },
        ...
      }
    """)

    System.halt(exit_code)
  end

  #-----------------------------------------------------------------------------
  # Logging helpers
  #-----------------------------------------------------------------------------
  require Logger

  def log(level, msg), do: Logger.log(level, msg)

  def log(level, msg, extra) do
    log(level, msg <> "\n\n" <> inspect(extra, pretty: true, limit: :infinity))
  end

  def debug(msg), do: log(:debug, msg)
  def debug(msg, extra), do: log(:debug, msg, extra)
  def info(msg), do: log(:info, msg)
  def info(msg, extra), do: log(:info, msg, extra)
  def error(msg), do: log(:error, msg)
  def error(msg, extra), do: log(:error, msg, extra)
  def warn(msg), do: log(:warn, msg)
  def warn(msg, extra), do: log(:warn, msg, extra)
end

#-------------------------------------------------------------------------------
# Contexts
#-------------------------------------------------------------------------------
defmodule Embeddings do
  @model "sentence-transformers/all-MiniLM-L12-v2"
  @serving_name __MODULE__

  def model(), do: @model

  # Loads the embedding model and tokenizer from HuggingFace, then starts an
  # Nx.Serving process for batched inference. Must be called before embed/1.
  def start do
    App.log(:info, "Loading embedding model #{@model}...")

    {:ok, model} = Bumblebee.load_model({:hf, @model})
    {:ok, tokenizer} = Bumblebee.load_tokenizer({:hf, @model})

    serving =
      Bumblebee.Text.TextEmbedding.text_embedding(
        model,
        tokenizer,
        compile: [batch_size: 2, sequence_length: 128],
        defn_options: [compiler: EXLA],
        output_pool: :mean_pooling,
        output_attribute: :hidden_state
      )

    Nx.Serving.start_link(
      serving: serving,
      name: @serving_name,
      batch_size: 2,
      batch_timeout: 100
    )
  end

  # Embeds a single string, returns {:ok, tensor}.
  def embed(text) do
    case Nx.Serving.batched_run(@serving_name, text) do
      %{embedding: embedding} -> {:ok, embedding}
      error -> {:error, error}
    end
  end

  # Cosine similarity between two pre-computed embedding tensors.
  def tensor_similarity(e1, e2), do: cosine_similarity(e1, e2)

  defp cosine_similarity(e1, e2) do
    e1 = Nx.flatten(e1)
    e2 = Nx.flatten(e2)

    Nx.divide(Nx.dot(e1, e2), Nx.multiply(Nx.LinAlg.norm(e1), Nx.LinAlg.norm(e2)))
    |> Nx.to_number()
  end
end

defmodule State do
  use Agent

  def start_link(), do: Agent.start_link(fn -> %{} end, name: __MODULE__)

  def db(ref), do: Agent.update(__MODULE__, &Map.put(&1, :db, ref))
  def db(), do: Agent.get(__MODULE__, &Map.get(&1, :db))
end

defmodule Store do
  @max_results 10

  #-----------------------------------------------------------------------------
  # Store management -- each store is a SQLite database file under
  # ~/.config/engram/<name>.db. The schema is created on first open.
  #-----------------------------------------------------------------------------
  def base_path(), do: [System.user_home!(), ".config", "engram"] |> Path.join()
  defp db_path(name), do: Path.join(base_path(), name <> ".db")

  def init() do
    File.mkdir_p!(base_path())
  end

  def open(name) do
    path = db_path(name)

    if store_exists?(name) do
      with {:ok, db} <- Exqlite.Sqlite3.open(path) do
        State.db(db)
        :ok
      else
        {:error, reason} -> {:error, "Failed to open store '#{name}': #{inspect(reason)}"}
      end
    else
      {:error, "Store '#{name}' does not exist. Use 'create' to create it."}
    end
  end

  def create(name) do
    init()

    if store_exists?(name) do
      {:error, "Store '#{name}' already exists."}
    else
      path = db_path(name)

      with {:ok, db} <- Exqlite.Sqlite3.open(path),
           :ok <- migrate(db),
           :ok <- Exqlite.Sqlite3.close(db) do
        {:ok, name}
      else
        {:error, reason} -> {:error, "Failed to create store '#{name}': #{inspect(reason)}"}
      end
    end
  end

  def list_stores() do
    init()

    base_path()
    |> File.ls!()
    |> Enum.filter(&String.ends_with?(&1, ".db"))
    |> Enum.map(&String.replace_suffix(&1, ".db", ""))
    |> then(&{:ok, &1})
  end

  def remove_store(name) do
    path = db_path(name)

    if File.exists?(path) do
      File.rm!(path)
      :ok
    else
      {:error, "Store '#{name}' does not exist."}
    end
  end

  #-----------------------------------------------------------------------------
  # Schema - single table for entries with content and cached embeddings. The
  # model column tracks which embedding model generated the vector, so we can
  # detect when a reindex is needed after a model change.
  #-----------------------------------------------------------------------------
  defp migrate(db) do
    :ok = Exqlite.Sqlite3.execute(db, """
      CREATE TABLE IF NOT EXISTS entries (
          slug      TEXT PRIMARY KEY
        , label     TEXT NOT NULL
        , content   TEXT NOT NULL
        , embedding BLOB
        , model     TEXT
      )
    """)
  end

  #-----------------------------------------------------------------------------
  # Entry operations
  #-----------------------------------------------------------------------------
  def list_entries() do
    db = State.db()
    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT label FROM entries ORDER BY label")
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    rows |> Enum.map(fn [label] -> label end)
  end

  def write(label, data, opts \\ []) do
    slug = slugify(label)
    content = "# #{label}\n\n#{data}"
    overwrite = Keyword.get(opts, :overwrite, false)

    with :ok <- check_overwrite(slug, label, overwrite),
         {:ok, embedding} <- Embeddings.embed(content),
         :ok <- upsert_entry(slug, label, content, embedding) do
      :ok
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Failed to write '#{label}': #{inspect(reason)}"}
    end
  end

  def read(slug) do
    with {:ok, stmt} <- prepare_and_bind("SELECT content FROM entries WHERE slug = ?1", [slug]),
         {:ok, content} <- fetch_one(stmt, slug) do
      {:ok, content}
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Failed to read '#{slug}': #{inspect(reason)}"}
    end
  end

  def search(query, max_results \\ @max_results) do
    with {:ok, query_embedding} <- Embeddings.embed(query),
         {:ok, rows} <- fetch_all_embeddings() do
      rows
      |> Enum.map(fn [content, embedding_blob] ->
        embedding = :erlang.binary_to_term(embedding_blob)
        score = Embeddings.tensor_similarity(query_embedding, embedding)
        {score, content}
      end)
      |> Enum.sort_by(&elem(&1, 0), :desc)
      |> Enum.take(max_results)
      |> then(&{:ok, &1})
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Search failed: #{inspect(reason)}"}
    end
  end

  #-----------------------------------------------------------------------------
  # Helpers -- private functions that encapsulate SQLite operations. Public
  # functions use `with` to compose these, reshaping errors into caller-
  # friendly messages at the boundary.
  #-----------------------------------------------------------------------------
  defp store_exists?(name) do
    name |> db_path() |> File.exists?()
  end

  defp check_overwrite(slug, label, overwrite) do
    case {entry_exists?(slug), overwrite} do
      {true, false} ->
        {:error, "A memory with label '#{label}' already exists. " <>
          "Read it first, then decide whether to overwrite, merge, or create a separate memory. " <>
          "Pass overwrite: true to replace it."}
      _ ->
        :ok
    end
  end

  defp prepare_and_bind(sql, params) do
    db = State.db()

    with {:ok, stmt} <- Exqlite.Sqlite3.prepare(db, sql),
         :ok <- Exqlite.Sqlite3.bind(stmt, params) do
      {:ok, stmt}
    end
  end

  defp fetch_one(stmt, slug) do
    db = State.db()

    result =
      case Exqlite.Sqlite3.step(db, stmt) do
        {:row, [value]} -> {:ok, value}
        :done -> {:error, "Entry '#{slug}' not found."}
      end

    :ok = Exqlite.Sqlite3.release(db, stmt)
    result
  end

  defp entry_exists?(slug) do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT 1 FROM entries WHERE slug = ?1")
    :ok = Exqlite.Sqlite3.bind(stmt, [slug])
    result = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)

    match?({:row, _}, result)
  end

  defp upsert_entry(slug, label, content, embedding) do
    db = State.db()
    blob = {:blob, :erlang.term_to_binary(embedding)}

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, """
      INSERT INTO entries (slug, label, content, embedding, model)
      VALUES (?1, ?2, ?3, ?4, ?5)
      ON CONFLICT(slug) DO UPDATE SET
        label = excluded.label,
        content = excluded.content,
        embedding = excluded.embedding,
        model = excluded.model
    """)

    :ok = Exqlite.Sqlite3.bind(stmt, [slug, label, content, blob, Embeddings.model()])
    :done = Exqlite.Sqlite3.step(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    :ok
  end

  defp fetch_all_embeddings() do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
      "SELECT content, embedding FROM entries WHERE embedding IS NOT NULL"
    )

    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    {:ok, rows}
  end

  defp fetch_all_content() do
    db = State.db()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db, "SELECT slug, content FROM entries")
    {:ok, rows} = Exqlite.Sqlite3.fetch_all(db, stmt)
    :ok = Exqlite.Sqlite3.release(db, stmt)
    {:ok, rows}
  end

  defp reindex_entries(rows) do
    db = State.db()
    model = Embeddings.model()

    {:ok, stmt} = Exqlite.Sqlite3.prepare(db,
      "UPDATE entries SET embedding = ?1, model = ?2 WHERE slug = ?3"
    )

    Enum.each(rows, fn [slug, content] ->
      App.info("Reindexing '#{slug}'...")
      {:ok, embedding} = Embeddings.embed(content)
      blob = {:blob, :erlang.term_to_binary(embedding)}
      :ok = Exqlite.Sqlite3.bind(stmt, [blob, model, slug])
      :done = Exqlite.Sqlite3.step(db, stmt)
    end)

    :ok = Exqlite.Sqlite3.release(db, stmt)
    :ok
  end

  def reindex() do
    with {:ok, rows} <- fetch_all_content(),
         :ok <- reindex_entries(rows) do
      App.info("Reindex complete. #{length(rows)} entries updated.")
      :ok
    else
      {:error, reason} when is_binary(reason) -> {:error, reason}
      {:error, reason} -> {:error, "Reindex failed: #{inspect(reason)}"}
    end
  end

  defp slugify(label) do
    label
    |> String.trim()
    |> String.downcase()
    |> String.replace(~r/[^a-z0-9\s_-]/, "")
    |> String.replace(~r/[\s_]+/, "-")
  end
end

#-------------------------------------------------------------------------------
# Process ARGV
#-------------------------------------------------------------------------------
{flags, argv, invalid} =
  System.argv()
  |> OptionParser.parse(
    switches: [
      help: :boolean,
      verbose: :boolean,
    ],
    aliases: [
      h: :help,
      v: :verbose,
    ]
  )

# Reject unrecognized flags
if invalid != [] do
  bad = Enum.map(invalid, fn {k, _} -> k end)
  App.error("Unrecognized flags: #{Enum.join(bad, ", ")}")
  App.help(1)
end

flags = Map.new(flags)

# Override logger level if --verbose is set
if flags[:verbose] do
  :logger.set_primary_config(:level, :debug)
end

State.start_link()

#-------------------------------------------------------------------------------
# Dispatch
#-------------------------------------------------------------------------------
case argv do
  _ when flags[:help] == true ->
    App.help(0)

  ["list"] ->
    case Store.list_stores() do
      {:ok, []} ->
        IO.puts("No stores found. Use 'create <name>' to create one.")

      {:ok, stores} ->
        IO.puts("Existing stores:")
        stores |> Enum.each(&IO.puts("  - #{&1}"))
    end

  ["create", name] ->
    case Store.create(name) do
      {:ok, name} ->
        IO.puts(:standard_error, """
        Created store '#{name}'.

        To start the MCP server:
          ./engram mcp #{name}

        To add to Claude Code:
          claude mcp add engram -- ./engram mcp #{name}

        Or add directly to ~/.claude.json:
          "<project-root>": {
            "mcpServers": {
              "engram": {
                "type": "stdio",
                "command": "./engram",
                "args": ["mcp", "#{name}"],
                "env": {}
              }
            }
          }
        """)

      {:error, reason} ->
        App.error(reason)
    end

  ["remove", name] ->
    case Store.remove_store(name) do
      :ok -> App.info("Removed store '#{name}'")
      {:error, reason} -> App.error(reason)
    end

  ["reindex", name] ->
    with :ok <- Store.open(name) do
      Nx.global_default_backend(EXLA.Backend)
      Embeddings.start()

      case Store.reindex() do
        :ok -> :ok
        {:error, reason} -> App.error(reason)
      end
    else
      {:error, reason} ->
        App.error(reason)
        System.halt(1)
    end

  ["mcp", name] ->
    case Store.open(name) do
      :ok ->
        App.info("Using store '#{name}'")
        Nx.global_default_backend(EXLA.Backend)
        Embeddings.start()
        McpServer.run()

      {:error, reason} ->
        App.error(reason)
        System.halt(1)
    end

  _ ->
    App.help(1)
end
